---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro i18n Notion Integration" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 min-h-screen dark:bg-slate-900 dark:text-slate-50 transition-colors duration-300">
        <header class="border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 sticky top-0 z-10">
            <div class="max-w-5xl mx-auto px-6 py-4">
                <div class="flex justify-between items-center mb-4">
                    <a href={`/${lang}/`} class="text-2xl font-extrabold bg-gradient-to-r from-blue-500 to-indigo-600 bg-clip-text text-transparent hover:opacity-80 transition-opacity">
                        {t('site.name')}
                    </a>
                    <nav class="flex space-x-4 border border-slate-200 dark:border-slate-700 rounded-full p-1 bg-slate-50 dark:bg-slate-800">
                        <a href={`/en/`} class={`px-3 py-1 rounded-full text-sm font-medium transition-colors ${lang === 'en' ? 'bg-white dark:bg-slate-700 shadow-sm' : 'hover:bg-slate-200 dark:hover:bg-slate-700'}`}>EN</a>
                        <a href={`/ja/`} class={`px-3 py-1 rounded-full text-sm font-medium transition-colors ${lang === 'ja' ? 'bg-white dark:bg-slate-700 shadow-sm' : 'hover:bg-slate-200 dark:hover:bg-slate-700'}`}>JA</a>
                        <a href={`/zh/`} class={`px-3 py-1 rounded-full text-sm font-medium transition-colors ${lang === 'zh' ? 'bg-white dark:bg-slate-700 shadow-sm' : 'hover:bg-slate-200 dark:hover:bg-slate-700'}`}>ZH</a>
                    </nav>
                </div>
                <nav class="flex gap-1 flex-wrap">
                    <a href={`/${lang}/`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${Astro.url.pathname === `/${lang}/` ? 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'}`}>
                        {t('nav.home')}
                    </a>
                    <a href={`/${lang}/daily/`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${Astro.url.pathname.startsWith(`/${lang}/daily`) ? 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'}`}>
                        {t('nav.daily')}
                    </a>
                    <a href={`/${lang}/tools/`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${Astro.url.pathname.startsWith(`/${lang}/tools`) ? 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'}`}>
                        {t('nav.tools')}
                    </a>
                    <a href={`/${lang}/cases/`} class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${Astro.url.pathname.startsWith(`/${lang}/cases`) ? 'bg-blue-100 dark:bg-blue-900 text-blue-700 dark:text-blue-200' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'}`}>
                        {t('nav.cases')}
                    </a>
                </nav>
            </div>
        </header>
		<main class="max-w-5xl mx-auto p-6 py-12">
			<slot />
		</main>
	</body>
</html>
