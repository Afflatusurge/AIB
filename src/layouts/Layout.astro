---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ConsentBanner from '../components/ConsentBanner.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  keywords?: string[] | string;
  ogImage?: string;
}

const { title, description = 'AI Solopreneur Guide - Daily briefs, tool reviews, and case studies for building an AI-powered one-person business.', keywords, ogImage } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const keywordContent = Array.isArray(keywords) ? keywords.join(', ') : keywords;
const GA_MEASUREMENT_ID = 'G-KRMNDMBYMK';
const docsLabel = lang === 'zh' ? '资料库' : lang === 'ja' ? 'ライブラリ' : 'Library';
const languageMenuLabel = lang === 'zh' ? '语言' : lang === 'ja' ? '言語' : 'Language';
const currentLanguageLabel = lang === 'zh' ? '中文' : lang === 'ja' ? '日本語' : 'EN';

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const languages = ['en', 'ja', 'zh'];
const pathWithoutLang = Astro.url.pathname
	.split('/')
	.filter((segment) => segment && !['en', 'ja', 'zh'].includes(segment))
	.join('/');
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		{keywordContent && <meta name="keywords" content={keywordContent} />}
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
		<link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
		<link rel="icon" type="image/png" href="/favicon-64x64.png" sizes="64x64" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		{ogImage && <meta property="og:image" content={ogImage} />}

		<!-- Hreflang Alternate Links -->
		{languages.map((langCode) => {
			const alternateUrl = new URL(`/${langCode}${pathWithoutLang ? '/' + pathWithoutLang : '/'}`, Astro.site);
			const langAttribute = langCode === 'zh' ? 'zh-CN' : langCode === 'ja' ? 'ja-JP' : 'en-US';
			return <link rel="alternate" hreflang={langAttribute} href={alternateUrl} />;
		})}
		<link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site)} />
	</head>
	<body class={`lang-${lang}`}>
        <header class="header">
            <div class="header-inner">
                <div class="brand-block">
                  <a href={`/${lang}/`} class="logo">
                    {lang === 'zh' ? 'AI一人公司指南' : lang === 'ja' ? 'AIソロプレナーガイド' : 'AI Solopreneur Guide'}
                  </a>
                  <p class="brand-kicker">
                    {lang === 'zh'
                      ? '为 AI 一人公司提供每日简报、工具评测与真实案例。'
                      : lang === 'ja'
                        ? 'AIソロプレナーのためのデイリーブリーフ、ツールレビュー、ケーススタディ。'
                        : 'Daily brief, tool reviews, and case studies for AI-first builders.'}
                  </p>
                </div>
                <div class="header-actions">
                  <nav class="nav-links" aria-label="Primary">
                      <a href={`/${lang}/`} class={Astro.url.pathname === `/${lang}/` ? 'active' : ''}>
                          {t('nav.home')}
                      </a>
                      <a href={`/${lang}/daily/`} class={Astro.url.pathname.startsWith(`/${lang}/daily`) ? 'active' : ''}>
                          {t('nav.daily')}
                      </a>
                      <a href={`/${lang}/tools/`} class={Astro.url.pathname.startsWith(`/${lang}/tools`) ? 'active' : ''}>
                          {t('nav.tools')}
                      </a>
                      <a href={`/${lang}/playbooks/`} class={Astro.url.pathname.startsWith(`/${lang}/playbooks`) ? 'active' : ''}>
                          {t('nav.playbooks')}
                      </a>
                      <a href={`/${lang}/cases/`} class={Astro.url.pathname.startsWith(`/${lang}/cases`) ? 'active' : ''}>
                          {t('nav.cases')}
                      </a>
                  </nav>
                  <a
                    href="https://docs.aiandbusiness.com/"
                    class="archive-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {docsLabel}
                  </a>
                  <details class="lang-switch" aria-label="Language switcher">
                    <summary class="lang-switch-trigger">
                      <span class="lang-switch-label">{languageMenuLabel}</span>
                      <span class="lang-switch-current">{currentLanguageLabel}</span>
                      <span class="lang-switch-caret" aria-hidden="true">▾</span>
                    </summary>
                    <div class="lang-switch-menu">
                      <a href={`/en${pathWithoutLang ? '/' + pathWithoutLang : '/'}`} class={lang === 'en' ? 'active' : ''}>English</a>
                      <a href={`/ja${pathWithoutLang ? '/' + pathWithoutLang : '/'}`} class={lang === 'ja' ? 'active' : ''}>日本語</a>
                      <a href={`/zh${pathWithoutLang ? '/' + pathWithoutLang : '/'}`} class={lang === 'zh' ? 'active' : ''}>中文</a>
                    </div>
                  </details>
                </div>
            </div>
        </header>
		<main>
			<slot />
		</main>
    <ConsentBanner lang={lang} />
		<script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
			(() => {
				const storageKey = 'aib-analytics-consent';
				const measurementId = GA_MEASUREMENT_ID;
				const scriptSrc = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
				const scriptSelector = `script[src="${scriptSrc}"]`;

				const getCookieNames = () =>
					document.cookie
						.split(';')
						.map((chunk) => chunk.trim().split('=')[0])
						.filter(Boolean);

				const clearCookie = (name) => {
					const hostname = window.location.hostname;
					const parts = hostname.split('.').filter(Boolean);
					const rootDomain = parts.length >= 2 ? `.${parts.slice(-2).join('.')}` : '';
					const domains = [undefined, hostname, `.${hostname}`, rootDomain].filter(Boolean);

					domains.forEach((domain) => {
						document.cookie = `${name}=; Max-Age=0; path=/; domain=${domain}; SameSite=Lax`;
					});

					document.cookie = `${name}=; Max-Age=0; path=/; SameSite=Lax`;
				};

				const disableAnalytics = () => {
					window[`ga-disable-${measurementId}`] = true;
					getCookieNames()
						.filter((name) => name === '_ga' || name.startsWith('_ga_') || name === '_gid' || name.startsWith('_gat'))
						.forEach(clearCookie);
				};

				const enableAnalytics = () => {
					if (window.__aibAnalyticsLoaded) return;

					window[`ga-disable-${measurementId}`] = false;
					window.dataLayer = window.dataLayer || [];
					window.gtag = window.gtag || function gtag(){ window.dataLayer.push(arguments); };
					window.gtag('js', new Date());
					window.gtag('config', measurementId, {
						anonymize_ip: true,
					});

					const existingScript = document.querySelector(scriptSelector);
					if (!existingScript) {
						const script = document.createElement('script');
						script.async = true;
						script.src = scriptSrc;
						document.head.appendChild(script);
					}

					window.__aibAnalyticsLoaded = true;
				};

				const applyConsent = (analyticsAllowed) => {
					if (analyticsAllowed) {
						enableAnalytics();
						return;
					}

					disableAnalytics();
				};

				const existing = window.localStorage.getItem(storageKey);
				applyConsent(existing === 'yes');

				window.addEventListener('aib:consent-updated', (event) => {
					applyConsent(!!event.detail?.analytics);
				});
			})();
		</script>
		<script is:inline>
			(() => {
				const setupTabGroup = (group) => {
				const triggers = Array.from(group.querySelectorAll('.article-tab-trigger'));
				const panels = Array.from(group.querySelectorAll('.article-tab-panel'));
				if (!triggers.length || !panels.length) return;

				const activate = (targetId) => {
					triggers.forEach((trigger) => {
						const isActive = trigger.dataset.tabTarget === targetId;
						trigger.classList.toggle('is-active', isActive);
						trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
					});
					panels.forEach((panel) => {
						panel.classList.toggle('is-active', panel.id === targetId);
					});
				};

				triggers.forEach((trigger) => {
					trigger.addEventListener('click', () => {
						const targetId = trigger.dataset.tabTarget;
						if (targetId) activate(targetId);
					});
				});

				const initial = triggers.find((trigger) => trigger.classList.contains('is-active'))?.dataset.tabTarget;
				if (initial) activate(initial);
			};

			const init = () => {
				document.querySelectorAll('[data-tab-group]').forEach((group) => setupTabGroup(group));
			};

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', init, { once: true });
			} else {
				init();
				}
			})();
		</script>
		</body>
</html>

<style is:global>
  /* Header */
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    background: rgba(249, 246, 239, 0.86);
    border-bottom: 1px solid var(--border-subtle);
  }
  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 18px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .brand-block {
    display: grid;
    gap: 4px;
  }
  .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .brand-kicker {
    font-size: 0.78rem;
    color: var(--text-muted);
    max-width: 30rem;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .nav-links {
    display: flex;
    gap: 2px;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
    padding: 8px 14px;
    border-radius: 999px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text-primary);
    background: var(--bg-card);
  }
  .archive-link {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: 1px solid var(--border-subtle);
    background: rgba(255, 251, 245, 0.88);
    border-radius: 999px;
    padding: 8px 12px;
    transition: all 0.2s;
    white-space: nowrap;
    box-shadow: 0 6px 16px rgba(32, 27, 24, 0.04);
  }
  .archive-link:hover {
    border-color: var(--border-hover);
    background: var(--accent-soft);
    transform: translateY(-1px);
  }
  .lang-switch {
    position: relative;
  }
  .lang-switch[open] {
    z-index: 60;
  }
  .lang-switch summary {
    list-style: none;
  }
  .lang-switch summary::-webkit-details-marker {
    display: none;
  }
  .lang-switch-trigger {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--border-subtle);
    background: var(--bg-card);
    border-radius: 999px;
    padding: 8px 12px;
    color: var(--text-primary);
    cursor: pointer;
    white-space: nowrap;
    box-shadow: 0 6px 16px rgba(32, 27, 24, 0.04);
  }
  .lang-switch-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .lang-switch-current {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--text-primary);
  }
  .lang-switch-caret {
    font-size: 0.76rem;
    color: var(--text-muted);
    transition: transform 0.2s ease;
  }
  .lang-switch[open] .lang-switch-caret {
    transform: rotate(180deg);
  }
  .lang-switch-menu {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    min-width: 9rem;
    display: grid;
    gap: 4px;
    padding: 8px;
    background: rgba(255, 251, 245, 0.98);
    border: 1px solid var(--border-subtle);
    border-radius: 18px;
    box-shadow: 0 18px 40px rgba(32, 27, 24, 0.12);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }
  .lang-switch-menu a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.84rem;
    font-weight: 600;
    padding: 9px 12px;
    border-radius: 12px;
    transition: all 0.2s;
    text-align: left;
    white-space: nowrap;
  }
  .lang-switch-menu a:hover,
  .lang-switch-menu a.active {
    color: var(--text-primary);
    background: var(--accent-soft);
  }
  .lang-ja .nav-links a,
  .lang-zh .nav-links a {
    font-size: 0.84rem;
    padding-inline: 11px;
  }

  /* Animations */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-in {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }

  /* Section divider */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-wrap: wrap;
      gap: 14px;
      padding: 16px 18px;
    }
    .brand-kicker {
      display: none;
    }
    .header-actions {
      width: 100%;
      justify-content: space-between;
      gap: 10px;
    }
    .nav-links {
      display: none;
    }
    .archive-link {
      order: 1;
      margin-right: auto;
    }
    .lang-switch {
      order: 2;
    }
    .lang-switch-trigger {
      padding: 7px 11px;
    }
    .lang-switch-label {
      display: none;
    }
  }
</style>
