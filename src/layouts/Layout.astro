---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'AI Solopreneur Guide - Daily briefs, tool reviews, and case studies for building an AI-powered one-person business.', ogImage } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const languages = ['en', 'ja', 'zh'];
---
<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Newsreader:opsz,wght@6..72,400;6..72,600;6..72,700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		{ogImage && <meta property="og:image" content={ogImage} />}

		<!-- Hreflang Alternate Links -->
		{languages.map((langCode) => {
			const pathWithoutLang = Astro.url.pathname
				.split('/')
				.filter((segment) => segment && !['en', 'ja', 'zh'].includes(segment))
				.join('/');
			const alternateUrl = new URL(`/${langCode}${pathWithoutLang ? '/' + pathWithoutLang : '/'}`, Astro.site);
			const langAttribute = langCode === 'zh' ? 'zh-CN' : langCode === 'ja' ? 'ja-JP' : 'en-US';
			return <link rel="alternate" hreflang={langAttribute} href={alternateUrl} />;
		})}
		<link rel="alternate" hreflang="x-default" href={new URL('/en/', Astro.site)} />
	</head>
	<body>
        <header class="header">
            <div class="header-inner">
                <div class="brand-block">
                  <a href={`/${lang}/`} class="logo">
                    {lang === 'zh' ? 'AI一人公司指南' : lang === 'ja' ? 'AIソロプレナーガイド' : 'AI Solopreneur Guide'}
                  </a>
                  <p class="brand-kicker">
                    {lang === 'zh' ? 'Daily brief, tool reviews, and case studies for AI-first builders.' : lang === 'ja' ? 'AIファーストな個人起業家のためのデイリーブリーフと実践レビュー。' : 'Daily brief, tool reviews, and case studies for AI-first builders.'}
                  </p>
                </div>
                <div class="header-actions">
                  <nav class="nav-links" aria-label="Primary">
                      <a href={`/${lang}/`} class={Astro.url.pathname === `/${lang}/` ? 'active' : ''}>
                          {t('nav.home')}
                      </a>
                      <a href={`/${lang}/daily/`} class={Astro.url.pathname.startsWith(`/${lang}/daily`) ? 'active' : ''}>
                          {t('nav.daily')}
                      </a>
                      <a href={`/${lang}/tools/`} class={Astro.url.pathname.startsWith(`/${lang}/tools`) ? 'active' : ''}>
                          {t('nav.tools')}
                      </a>
                      <a href={`/${lang}/cases/`} class={Astro.url.pathname.startsWith(`/${lang}/cases`) ? 'active' : ''}>
                          {t('nav.cases')}
                      </a>
                  </nav>
                  <div class="lang-switch" aria-label="Language switcher">
                      <a href={`/en/`} class={lang === 'en' ? 'active' : ''}>EN</a>
                      <a href={`/ja/`} class={lang === 'ja' ? 'active' : ''}>JA</a>
                      <a href={`/zh/`} class={lang === 'zh' ? 'active' : ''}>ZH</a>
                  </div>
                </div>
            </div>
        </header>
		<main>
			<slot />
		</main>
	</body>
</html>

<style is:global>
  /* Header */
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    background: rgba(249, 246, 239, 0.86);
    border-bottom: 1px solid var(--border-subtle);
  }
  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 18px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }
  .brand-block {
    display: grid;
    gap: 4px;
  }
  .logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .brand-kicker {
    font-size: 0.78rem;
    color: var(--text-muted);
    max-width: 30rem;
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .nav-links {
    display: flex;
    gap: 2px;
  }
  .nav-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.88rem;
    font-weight: 700;
    padding: 8px 14px;
    border-radius: 999px;
    transition: all 0.2s;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--text-primary);
    background: var(--bg-card);
  }
  .lang-switch {
    display: flex;
    gap: 2px;
    background: var(--bg-card);
    border-radius: 999px;
    padding: 3px;
    border: 1px solid var(--border-subtle);
  }
  .lang-switch a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 600;
    padding: 5px 11px;
    border-radius: 999px;
    transition: all 0.2s;
  }
  .lang-switch a.active {
    color: var(--text-primary);
    background: var(--accent-soft);
  }

  /* Animations */
  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-in {
    animation: fadeInUp 0.6s ease-out forwards;
    opacity: 0;
  }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }

  /* Section divider */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .header-inner {
      flex-wrap: wrap;
      gap: 14px;
      padding: 16px 18px;
    }
    .brand-kicker {
      display: none;
    }
    .header-actions {
      width: 100%;
      justify-content: space-between;
    }
    .nav-links {
      display: none;
    }
  }
</style>
