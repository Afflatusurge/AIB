---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import SignalFeed from '../../components/SignalFeed.astro';
import FeaturedCards from '../../components/FeaturedCards.astro';
import NewsletterCTA from '../../components/NewsletterCTA.astro';
import Footer from '../../components/Footer.astro';
import { getDailyBriefs, getToolReviews, getCaseStudies } from '../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Fetch content from Notion (language-aware)
const dailyBriefs = await getDailyBriefs(lang as 'en' | 'zh' | 'ja');
const toolReviews = await getToolReviews(lang as 'en' | 'zh' | 'ja');
const caseStudies = await getCaseStudies(lang as 'en' | 'zh' | 'ja');
---

<Layout title={t('site.name')}>
  <Hero lang={lang} t={t} />
  <div class="section-divider"></div>
  <BentoGrid lang={lang} t={t} />
  <div class="section-divider"></div>
  <SignalFeed lang={lang} t={t} briefs={dailyBriefs} />
  <div class="section-divider"></div>
  <FeaturedCards lang={lang} t={t} tools={toolReviews} cases={caseStudies} />
  <div class="section-divider"></div>
  <NewsletterCTA lang={lang} />
  <Footer lang={lang} />
</Layout>