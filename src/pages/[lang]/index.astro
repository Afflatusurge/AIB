---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import BentoGrid from '../../components/BentoGrid.astro';
import SignalFeed from '../../components/SignalFeed.astro';
import FeaturedCards from '../../components/FeaturedCards.astro';
import PlaybookShelf from '../../components/PlaybookShelf.astro';
import Footer from '../../components/Footer.astro';
import { getToolReviews, getCaseStudies, getPlaybooks } from '../../lib/notion';
import { listPublishedBriefs } from '../../lib/supabase';
import { useTranslations, getLangFromUrl } from '../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

let dailyBriefs = [] as Awaited<ReturnType<typeof listPublishedBriefs>>;
try {
  dailyBriefs = await listPublishedBriefs(lang as 'en' | 'zh' | 'ja');
} catch (error) {
  console.error('[homepage] Failed to fetch daily briefs at build time:', error);
}

const [toolReviews, caseStudies, playbooks] = await Promise.all([
  getToolReviews(lang as 'en' | 'zh' | 'ja'),
  getCaseStudies(lang as 'en' | 'zh' | 'ja'),
  getPlaybooks(lang as 'en' | 'zh' | 'ja'),
]);

const leadBrief = dailyBriefs.find((item) => item.featured) || dailyBriefs[0];
const leadTool = toolReviews.find((item) => item.featured) || toolReviews[0];
const leadCase = caseStudies.find((item) => item.featured) || caseStudies[0];

const prioritizedBriefs = leadBrief
  ? [leadBrief, ...dailyBriefs.filter((item) => item.id !== leadBrief.id)]
  : dailyBriefs;
const prioritizedTools = leadTool
  ? [leadTool, ...toolReviews.filter((item) => item.id !== leadTool.id)]
  : toolReviews;
const prioritizedCases = leadCase
  ? [leadCase, ...caseStudies.filter((item) => item.id !== leadCase.id)]
  : caseStudies;

const homepageTitle = lang === 'zh'
  ? 'AI一人公司指南 | 每日简报、工具评测与实战指南'
  : lang === 'ja'
    ? 'AIソロプレナーガイド | デイリーブリーフ・ツールレビュー・プレイブック'
    : 'AI Solopreneur Guide | Daily Brief, Tool Reviews, and Playbooks';

const homepageDescription = lang === 'zh'
  ? '从 AI 噪音，到商业信号。每日简报、工具评测、案例分析与实战指南，帮助你筛选重要信息、理解趋势，并一步步落地执行。'
  : lang === 'ja'
    ? 'AIのノイズを、ビジネスのシグナルへ。デイリーブリーフ、ツールレビュー、ケース、プレイブックで、重要な情報を理解し、実行へつなげます。'
    : 'AI, filtered for decisions and execution. Daily AI briefings, tool reviews, case studies, and playbooks to help builders understand what matters and apply it step by step.';

const homepageKeywords = lang === 'en'
  ? [
      'AI news summary',
      'daily AI briefing',
      'AI trends today',
      'AI tool reviews',
      'best AI tools 2026',
      'AI tools comparison',
      'AI case studies',
      'AI in business examples',
      'AI workflows',
      'AI automation guide',
    ]
  : undefined;
---

<Layout title={homepageTitle} description={homepageDescription} keywords={homepageKeywords}>
  <Hero
    lang={lang}
    t={t}
    leadBrief={leadBrief}
    leadTool={leadTool}
    leadCase={leadCase}
  />
  <div class="section-divider"></div>
  <BentoGrid
    lang={lang}
    t={t}
    briefs={prioritizedBriefs.slice(0, 3)}
    tools={prioritizedTools.slice(0, 3)}
    playbooks={playbooks.slice(0, 3)}
  />
  <div class="section-divider"></div>
  <SignalFeed lang={lang} t={t} briefs={dailyBriefs} />
  <div class="section-divider"></div>
  <FeaturedCards
    lang={lang}
    t={t}
    briefs={prioritizedBriefs}
    tools={prioritizedTools}
    cases={prioritizedCases}
  />
  <div class="section-divider"></div>
  <PlaybookShelf lang={lang} playbooks={playbooks.slice(0, 4)} />
  <Footer lang={lang} />
  <script is:inline define:vars={{ lang }}>
    (() => {
      const endpoint = `/api/briefs?lang=${lang}&limit=6`;
      const escapeHtml = (value) =>
        String(value ?? '')
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');

      const setText = (selector, value) => {
        const node = document.querySelector(selector);
        if (node) node.textContent = value;
      };

      const updateHero = (brief) => {
        if (!brief) return;
        const link = document.querySelector('[data-live-hero-brief]');
        if (!(link instanceof HTMLAnchorElement)) return;
        link.href = `/${lang}/daily/${brief.slug || brief.id}/`;
        const title = link.querySelector('[data-live-hero-title]');
        const meta = link.querySelector('[data-live-hero-meta]');
        if (title) title.textContent = brief.title;
        if (meta) meta.textContent = brief.commentary || brief.category || '';
        link.classList.remove('is-disabled');
      };

      const updateBento = (briefs) => {
        const list = document.querySelector('[data-live-bento-briefs]');
        if (!list) return;

        const entries = briefs.slice(0, 3);
        const rows = Array.from(list.querySelectorAll('li'));
        if (!entries.length || !rows.length) return;

        entries.forEach((brief, index) => {
          const row = rows[index];
          if (!row) return;
          const link = row.querySelector('a');
          const meta = row.querySelector('span');
          if (link) {
            link.textContent = brief.title;
            link.setAttribute('href', `/${lang}/daily/${brief.slug || brief.id}`);
          }
          if (meta) {
            meta.textContent = brief.category || '';
          }
          row.classList.remove('empty-row');
        });

        rows.slice(entries.length).forEach((row) => {
          row.style.display = 'none';
        });
      };

      const updateSignalFeed = (briefs) => {
        const container = document.querySelector('[data-live-signal-items]');
        if (!container) return;
        const rows = Array.from(container.querySelectorAll('.signal-item'));
        const entries = briefs.slice(0, 6);
        if (!entries.length || !rows.length) return;

        const categoryClass = {
          LLM: 'llm',
          Agent: 'agent',
          Business: 'business',
          Coding: 'coding',
          Hardware: 'hardware',
          Image: 'image',
          Video: 'video',
        };

        entries.forEach((brief, index) => {
          const row = rows[index];
          if (!(row instanceof HTMLAnchorElement)) return;

          const category = brief.category || 'AI';
          const impact = brief.impact || 'Notable';
          const categorySlug = categoryClass[category] || 'llm';
          const impactSlug = String(impact).toLowerCase();

          row.href = `/${lang}/daily/${brief.slug || brief.id}`;

          const indexNode = row.querySelector('.signal-index');
          const categoryNode = row.querySelector('.signal-category');
          const impactNode = row.querySelector('.signal-impact');
          const titleNode = row.querySelector('h4');
          const snippetNode = row.querySelector('p');

          if (indexNode) indexNode.textContent = String(index + 1).padStart(2, '0');
          if (categoryNode) {
            categoryNode.textContent = category;
            categoryNode.className = `signal-category ${categorySlug}`;
          }
          if (impactNode) {
            impactNode.textContent = impact;
            impactNode.className = `signal-impact ${impactSlug}`;
          }
          if (titleNode) titleNode.textContent = brief.title;
          if (snippetNode) snippetNode.textContent = brief.snippet || '';

          row.style.display = '';
        });

        rows.slice(entries.length).forEach((row) => {
          row.style.display = 'none';
        });
      };

      fetch(endpoint, { headers: { accept: 'application/json' } })
        .then((response) => (response.ok ? response.json() : null))
        .then((payload) => {
          if (!payload?.ok || !Array.isArray(payload.briefs) || !payload.briefs.length) return;
          updateHero(payload.briefs[0]);
          updateBento(payload.briefs);
          updateSignalFeed(payload.briefs);
        })
        .catch((error) => {
          console.warn('[homepage] brief refresh skipped:', error);
        });
    })();
  </script>
</Layout>
