---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import DailyDeskPage from '../../../components/list-pages/DailyDeskPage.astro';
import { listPublishedBriefs } from '../../../lib/supabase';
import { getPaginatedListing } from '../../../lib/pagination';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

// Dynamic / SSR: the list is backed by Supabase (populated daily by the
// OpenAI web-search ingest cron at /api/cron/ingest). No redeploy needed.
export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const briefs = await listPublishedBriefs(lang as 'en' | 'zh' | 'ja');
const listing = getPaginatedListing(briefs, 1);

Astro.response.headers.set(
  'Cache-Control',
  'public, s-maxage=3600, stale-while-revalidate=86400'
);
---

<Layout title={`${t('nav.daily')} - ${t('site.name')}`}>
  <DailyDeskPage
    lang={lang}
    t={t}
    leadBrief={listing.leadItem as any}
    briefs={listing.entries as any}
    currentPage={listing.currentPage}
    totalPages={listing.totalPages}
  />
  <Footer lang={lang} />
</Layout>
