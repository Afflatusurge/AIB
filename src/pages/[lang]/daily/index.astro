---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import DailyDeskPage from '../../../components/list-pages/DailyDeskPage.astro';
import { getDailyBriefs } from '../../../lib/notion';
import { getPaginatedListing } from '../../../lib/pagination';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const dailyBriefs = await getDailyBriefs(lang as 'en' | 'zh' | 'ja');
const listing = getPaginatedListing(dailyBriefs, 1);
---

<Layout title={`${t('nav.daily')} - ${t('site.name')}`}>
  <DailyDeskPage
    lang={lang}
    t={t}
    leadBrief={listing.leadItem}
    briefs={listing.entries}
    currentPage={listing.currentPage}
    totalPages={listing.totalPages}
  />
  <Footer lang={lang} />
</Layout>
