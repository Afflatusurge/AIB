---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { getDailyBriefs } from '../../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const dailyBriefs = await getDailyBriefs(lang as 'en' | 'zh' | 'ja');

function impactClass(impact: string): string {
  const i = (impact || '').toLowerCase();
  if (i.includes('major') || i === 'high') return 'impact-major';
  if (i.includes('notable') || i === 'medium') return 'impact-notable';
  return 'impact-routine';
}
---

<Layout title={`${t('nav.daily')} - ${t('site.name')}`}>
  <section class="page-section">
    <div class="container">
      <div class="page-header fade-in">
        <h1>{t('nav.daily')}</h1>
        <p>{t('section.daily.desc')}</p>
      </div>

      <div class="card-grid">
        {dailyBriefs.map((brief, i) => (
          <article class="content-card fade-in" style={`animation-delay: ${i * 60}ms`}>
            <div class="card-meta">
              <span class="card-badge">{brief.category || 'AI'}</span>
              {brief.impact && <span class={`card-badge ${impactClass(brief.impact)}`}>{brief.impact}</span>}
            </div>
            <div class="card-date">{brief.date}</div>
            <h2>
              <a href={`/${lang}/daily/${brief.slug || brief.id}/`}>{brief.title}</a>
            </h2>
            <p class="card-snippet">{brief.snippet}</p>
            <div class="card-footer">
              <a href={`/${lang}/daily/${brief.slug || brief.id}/`} class="read-more">
                {t('read.more')} →
              </a>
            </div>
          </article>
        ))}
        {dailyBriefs.length === 0 && (
          <div class="empty-state">No daily briefs yet.</div>
        )}
      </div>
    </div>
  </section>
  <Footer lang={lang} />
</Layout>
