---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { getDailyBriefs, getPageContent } from '../../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export async function getStaticPaths() {
  const langs: Array<'en' | 'ja' | 'zh'> = ['en', 'ja', 'zh'];
  const all: any[] = [];
  for (const l of langs) {
    const briefs = await getDailyBriefs(l);
    briefs.forEach((brief, idx) => {
      all.push({
        params: { lang: l, slug: brief.slug || brief.id },
        props: { brief, briefs, idx },
      });
    });
  }
  return all;
}

interface Props {
  brief: any;
  briefs: any[];
  idx: number;
}

const { brief, briefs, idx } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prevBrief = idx > 0 ? briefs[idx - 1] : null;
const nextBrief = idx < briefs.length - 1 ? briefs[idx + 1] : null;
const bodyHtml = await getPageContent(brief.id);
const relatedBriefs = briefs.filter((item) => item.id !== brief.id).slice(0, 3);
const headingMatches = Array.from(bodyHtml.matchAll(/<h2>(.*?)<\/h2>/g));
const headingItems = headingMatches.map((match, i) => ({
  id: `section-${i + 1}`,
  title: match[1].replace(/<[^>]+>/g, ''),
}));
const headingQueue = [...headingItems];
const processedBodyHtml = headingMatches.length
  ? bodyHtml.replace(/<h2>/g, () => {
      const heading = headingQueue.shift();
      return heading ? `<h2 id="${heading.id}">` : '<h2>';
    })
  : bodyHtml;
const hasBodyContent = !!processedBodyHtml.trim();
const uiText = {
  signal: lang === 'zh' ? '信号' : lang === 'ja' ? 'シグナル' : 'Signal',
  impact: lang === 'zh' ? '影响' : lang === 'ja' ? '影響' : 'Impact',
  whyItMatters: lang === 'zh' ? '为什么重要' : lang === 'ja' ? 'なぜ重要か' : 'Why it matters',
  editorsNote: lang === 'zh' ? '编辑注记' : lang === 'ja' ? '編集メモ' : 'Editor’s note',
  whyNow: lang === 'zh' ? '为什么是现在' : lang === 'ja' ? 'なぜ今か' : 'Why now',
  thisBrief: lang === 'zh' ? '本篇简报' : lang === 'ja' ? 'このブリーフ' : 'This brief',
  onThisPage: lang === 'zh' ? '本页目录' : lang === 'ja' ? 'このページ' : 'On this page',
  moreFromDaily: lang === 'zh' ? '更多每日简报' : lang === 'ja' ? 'さらに読むデイリーブリーフ' : 'More from daily',
  continueReading: lang === 'zh' ? '继续阅读' : lang === 'ja' ? '続きを読む' : 'Continue reading',
  summary: lang === 'zh' ? '摘要' : lang === 'ja' ? '要約' : 'Summary',
  editorialNote: lang === 'zh' ? '编辑说明' : lang === 'ja' ? '編集コメント' : 'Editorial note',
  source: lang === 'zh' ? '来源' : lang === 'ja' ? '参照元' : 'Source',
  readOriginalCoverage: lang === 'zh' ? '查看原始报道 →' : lang === 'ja' ? '元記事を読む →' : 'Read the original coverage →',
} as const;

const summaryCards = [
  {
    label: uiText.signal,
    value: brief.category || 'AI',
  },
  {
    label: uiText.impact,
    value: brief.impact || 'Notable',
  },
  {
    label: uiText.whyItMatters,
    value: brief.whyItMatters || brief.commentary || brief.snippet || (lang === 'zh' ? '需要补充一句判断。' : lang === 'ja' ? '一言の判断を補足すると良いです。' : 'Add one sharp editorial takeaway here.'),
  },
];
const recommendationIntro = lang === 'zh'
  ? '从当前信号继续延伸，看更多值得判断的更新。'
  : lang === 'ja'
    ? 'いまのシグナルから、次に読むべき更新へつなげます。'
    : 'Move from this signal into adjacent updates worth your attention.';
---

<Layout title={`${brief.title} - ${t('site.name')}`}>
  <section class="page-section">
    <div class="container">
      <article class="article-shell fade-in">
        <header class="article-hero">
          <div class="article-tags">
            <span class="card-badge">{brief.category || 'AI'}</span>
            {brief.impact && <span class="card-badge impact-major">{brief.impact}</span>}
          </div>
          <h1>{brief.title}</h1>
          {brief.snippet && <p class="article-dek">{brief.snippet}</p>}
          <div class="article-meta">
            <time datetime={brief.date}>{brief.date}</time>
            <span>·</span>
            <span>{brief.category}</span>
          </div>
          <div class="article-lead-grid">
            <div class="article-lead-note">
              <p class="article-lead-label">{uiText.editorsNote}</p>
              <p>{brief.commentary || brief.whyItMatters || brief.snippet}</p>
            </div>
            <div class="article-lead-note alt">
              <p class="article-lead-label">{uiText.whyNow}</p>
              <p>{brief.whyItMatters || brief.snippet || brief.commentary}</p>
            </div>
          </div>
        </header>

        <div class="article-layout">
          <aside class="article-rail">
            <div class="rail-card">
              <p class="rail-label">{uiText.thisBrief}</p>
              <ul class="rail-list">
                <li><strong>{lang === 'zh' ? '栏目' : lang === 'ja' ? '欄' : 'Desk'}</strong><span>{t('nav.daily')}</span></li>
                <li><strong>{lang === 'zh' ? '类别' : lang === 'ja' ? '分類' : 'Category'}</strong><span>{brief.category || 'AI'}</span></li>
                <li><strong>{lang === 'zh' ? '影响' : lang === 'ja' ? '影響' : 'Impact'}</strong><span>{brief.impact || 'Notable'}</span></li>
              </ul>
              {brief.sourceUrl && (
                <a class="rail-link" href={brief.sourceUrl} target="_blank" rel="noopener">
                  {lang === 'zh' ? '查看原始来源 →' : lang === 'ja' ? '元ソースを見る →' : 'View source →'}
                </a>
              )}
            </div>
            {headingItems.length > 0 && (
              <div class="rail-card">
                <p class="rail-label">{uiText.onThisPage}</p>
                <ul class="related-list">
                  {headingItems.map((item) => (
                    <li><a href={`#${item.id}`}>{item.title}</a></li>
                  ))}
                </ul>
              </div>
            )}
            {relatedBriefs.length > 0 && (
              <div class="rail-card">
                <p class="rail-label">{uiText.moreFromDaily}</p>
                <ul class="related-list">
                  {relatedBriefs.map((item) => (
                    <li><a href={`/${lang}/daily/${item.slug || item.id}/`}>{item.title}</a></li>
                  ))}
                </ul>
              </div>
            )}
          </aside>

          <div class="article-column">
            <div class="summary-grid">
              {summaryCards.map((card) => (
                <section class="summary-card">
                  <p class="summary-label">{card.label}</p>
                  <div class="summary-value">{card.value}</div>
                </section>
              ))}
            </div>
            <div class="article-body">
              {hasBodyContent ? (
                <Fragment set:html={processedBodyHtml} />
              ) : (
                <>
                  {brief.snippet && (
                    <>
                      <h2>{uiText.summary}</h2>
                      <p>{brief.snippet}</p>
                    </>
                  )}
                  {brief.commentary && (
                    <>
                      <h2>{uiText.editorialNote}</h2>
                      <p>{brief.commentary}</p>
                    </>
                  )}
                  {brief.whyItMatters && (
                    <>
                      <h2>{uiText.whyItMatters}</h2>
                      <p>{brief.whyItMatters}</p>
                    </>
                  )}
                  {brief.sourceUrl && (
                    <>
                      <h2>{uiText.source}</h2>
                      <p>
                        <a href={brief.sourceUrl} target="_blank" rel="noopener">
                          {uiText.readOriginalCoverage}
                        </a>
                      </p>
                    </>
                  )}
                </>
              )}
            </div>
          </div>
        </div>

        {(prevBrief || nextBrief) && (
          <div class="article-nav">
            {prevBrief ? (
              <a href={`/${lang}/daily/${prevBrief.slug || prevBrief.id}/`} class="prev">
                <div class="nav-label">← {lang === 'zh' ? '上一篇' : lang === 'ja' ? '前へ' : 'Previous'}</div>
                <div class="nav-title">{prevBrief.title}</div>
              </a>
            ) : <div />}
            {nextBrief ? (
              <a href={`/${lang}/daily/${nextBrief.slug || nextBrief.id}/`} class="next">
                <div class="nav-label">{lang === 'zh' ? '下一篇' : lang === 'ja' ? '次へ' : 'Next'} →</div>
                <div class="nav-title">{nextBrief.title}</div>
              </a>
            ) : <div />}
          </div>
        )}

        {relatedBriefs.length > 0 && (
          <section class="article-recommendations">
            <div class="article-recommendations-head">
              <p class="article-recommendations-kicker">{uiText.continueReading}</p>
              <h2>{lang === 'zh' ? '更多今日信号' : lang === 'ja' ? 'さらに読む今日のシグナル' : 'More daily signals'}</h2>
              <p>{recommendationIntro}</p>
            </div>
            <div class="article-recommendations-grid">
              {relatedBriefs.map((item) => (
                <a href={`/${lang}/daily/${item.slug || item.id}/`} class="article-rec-card">
                  <div class="article-rec-meta">
                    <span>{item.category || 'AI'}</span>
                    <span>{item.impact || 'Notable'}</span>
                  </div>
                  <h3>{item.title}</h3>
                  <p>{item.whyItMatters || item.commentary || item.snippet}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        <div class="article-back">
          <a href={`/${lang}/daily/`}>← {t('nav.daily')}</a>
        </div>
      </article>
    </div>
  </section>
  <Footer lang={lang} />
</Layout>
