---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import ToolDeskPage from '../../../components/list-pages/ToolDeskPage.astro';
import { getToolReviews } from '../../../lib/notion';
import { getPaginatedListing } from '../../../lib/pagination';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const toolReviews = await getToolReviews(lang as 'en' | 'zh' | 'ja');
const listing = getPaginatedListing(toolReviews, 1);
---

<Layout title={`${t('nav.tools')} - ${t('site.name')}`}>
  <ToolDeskPage
    lang={lang}
    t={t}
    leadTool={listing.leadItem}
    tools={listing.entries}
    currentPage={listing.currentPage}
    totalPages={listing.totalPages}
  />
  <Footer lang={lang} />
</Layout>
