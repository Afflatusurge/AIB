---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { getToolReviews } from '../../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const toolReviews = await getToolReviews(lang as 'en' | 'zh' | 'ja');
const leadTool = toolReviews.find((item) => item.featured) || toolReviews[0];
const moreTools = leadTool
  ? toolReviews.filter((item) => item.id !== leadTool.id)
  : [];
---

<Layout title={`${t('nav.tools')} - ${t('site.name')}`}>
  <section class="page-section">
    <div class="container">
      <div class="page-header fade-in">
        <p class="section-kicker">Review Desk</p>
        <h1>{t('nav.tools')}</h1>
        <p>{lang === 'zh' ? '把“有哪些工具”改成“哪些工具值得上手”，并且用价格、适配人群和工作流视角去写。' : lang === 'ja' ? '単なるツール一覧ではなく、誰に合うか、いくらか、どのワークフローに合うかで評価します。' : 'A review desk for deciding which AI tools are actually worth adopting, paying for, and integrating into a one-person business.'}</p>
      </div>

      {leadTool ? (
        <div class="list-shell fade-in">
          <article class="lead-entry">
            {leadTool.coverImage && (
              <div class="lead-entry-image">
                <img src={leadTool.coverImage} alt={leadTool.title} loading="lazy" />
              </div>
            )}
            <div class="lead-entry-meta">
              {leadTool.category && <span class="card-badge">{leadTool.category}</span>}
              {leadTool.bestFor
                ? <span class="card-badge impact-notable">{leadTool.bestFor}</span>
                : leadTool.pricing && <span class="card-badge impact-notable">{leadTool.pricing}</span>}
            </div>
            <div class="lead-entry-date">{leadTool.date}</div>
            <h2>
              <a href={`/${lang}/tools/${leadTool.slug || leadTool.id}/`}>{leadTool.title}</a>
            </h2>
            <p>{leadTool.snippet}</p>
            <div class="lead-entry-actions">
              <a href={`/${lang}/tools/${leadTool.slug || leadTool.id}/`} class="read-more">
                {t('read.more')} →
              </a>
              <span class="lead-entry-note">{lang === 'zh' ? '标杆评测' : lang === 'ja' ? '基幹レビュー' : 'Cornerstone review'}</span>
            </div>
          </article>

          <aside class="list-aside">
            <div class="aside-card">
              <h3>{lang === 'zh' ? '评测标准' : lang === 'ja' ? 'レビュー基準' : 'Review lens'}</h3>
              <ul class="aside-list">
                <li>{lang === 'zh' ? '是否替代现有人工流程' : lang === 'ja' ? '既存作業を置き換えられるか' : 'Can it replace real manual work?'}</li>
                <li>{lang === 'zh' ? '价格是否适合独立创业者' : lang === 'ja' ? '個人起業家にとって価格が妥当か' : 'Is the pricing realistic for solo builders?'}</li>
                <li>{lang === 'zh' ? '接入门槛和学习成本如何' : lang === 'ja' ? '導入と学習のコストはどうか' : 'What is the setup and learning cost?'}</li>
              </ul>
            </div>
            <div class="aside-card">
              <h3>{lang === 'zh' ? '迁移重点' : lang === 'ja' ? '移行の優先度' : 'Migration focus'}</h3>
              <p>{lang === 'zh' ? '你现在的真实库已经有 `Best For`，下一步最值得补的是 `Verdict` 和 `Workflow Fit`，这样列表页和详情页都能更像专业评测。' : lang === 'ja' ? '現行DBには `Best For` があるので、次は `Verdict` と `Workflow Fit` を足すとレビュー感が強くなります。' : 'Your real database already has `Best For`. The next highest-value additions are `Verdict` and `Workflow Fit`, which will make the review system feel much more editorial.'}</p>
            </div>
          </aside>
        </div>
      ) : null}

      <div class="card-grid editorial-list">
        {moreTools.map((tool, i) => {
          const rating = Number(tool.rating) || 0;
          return (
            <article class="content-card fade-in" style={`animation-delay: ${i * 60}ms`}>
            {tool.coverImage && (
              <div class="card-cover">
                <img src={tool.coverImage} alt={tool.title} loading="lazy" />
              </div>
            )}
            <div class="card-meta">
              <span class="card-badge">{tool.category || 'AI'}</span>
              {tool.bestFor
                ? <span class="card-badge impact-notable">{tool.bestFor}</span>
                : tool.pricing && <span class="card-badge impact-notable">{tool.pricing}</span>}
            </div>
              <div class="card-date">{tool.date}</div>
              <h2>
                <a href={`/${lang}/tools/${tool.slug || tool.id}/`}>{tool.title}</a>
              </h2>
              <p class="card-snippet">{tool.snippet}</p>
              <div class="card-footer">
                <a href={`/${lang}/tools/${tool.slug || tool.id}/`} class="read-more">
                  {t('read.more')} →
                </a>
                <span class="rating">
                  {[0,1,2,3,4].map((s) => (
                    <span class={s < Math.floor(rating) ? '' : 'star-empty'}>★</span>
                  ))}
                </span>
              </div>
            </article>
          );
        })}
        {toolReviews.length === 0 && (
          <div class="empty-state">No tool reviews yet.</div>
        )}
      </div>
    </div>
  </section>
  <Footer lang={lang} />
</Layout>

<style>
  .list-shell {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.46fr);
    gap: 18px;
    margin-bottom: 28px;
  }
  .lead-entry,
  .aside-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 24px;
  }
  .lead-entry {
    box-shadow: 0 16px 40px rgba(32, 27, 24, 0.04);
  }
  .lead-entry-image {
    margin: -8px -8px 18px;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 16 / 8.6;
    background: linear-gradient(135deg, rgba(177, 90, 53, 0.12), rgba(61, 100, 120, 0.14));
  }
  .lead-entry-image img,
  .card-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .lead-entry-meta {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 14px;
  }
  .lead-entry-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    margin-bottom: 16px;
  }
  .lead-entry h2 {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
    margin-bottom: 14px;
  }
  .lead-entry p {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.8;
    max-width: 46rem;
  }
  .lead-entry-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-top: 22px;
    padding-top: 18px;
    border-top: 1px solid var(--border-subtle);
  }
  .lead-entry-note {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .list-aside {
    display: grid;
    gap: 18px;
  }
  .aside-card h3 {
    font-family: var(--font-display);
    font-size: 1.85rem;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 12px;
  }
  .aside-card p,
  .aside-list li {
    color: var(--text-secondary);
    font-size: 0.95rem;
    line-height: 1.75;
  }
  .aside-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }
  .aside-list li {
    padding-top: 10px;
    border-top: 1px solid var(--border-subtle);
  }
  .card-cover {
    margin: -6px -6px 18px;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, rgba(177, 90, 53, 0.12), rgba(61, 100, 120, 0.14));
  }
  @media (max-width: 900px) {
    .list-shell {
      grid-template-columns: 1fr;
    }
  }
</style>
