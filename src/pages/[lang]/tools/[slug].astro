---
import Layout from '../../../layouts/Layout.astro';
import { getToolReviews } from '../../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export async function getStaticPaths() {
  const toolReviews = await getToolReviews();

  return [
    ...toolReviews.flatMap(tool => [
      { params: { lang: 'en', slug: tool.slug }, props: { tool } },
      { params: { lang: 'ja', slug: tool.slug }, props: { tool } },
      { params: { lang: 'zh', slug: tool.slug }, props: { tool } },
    ])
  ];
}

interface Props {
  tool: any;
}

const { tool } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const allTools = await getToolReviews();
const toolIndex = allTools.findIndex(t => t.slug === tool.slug);
const prevTool = toolIndex > 0 ? allTools[toolIndex - 1] : null;
const nextTool = toolIndex < allTools.length - 1 ? allTools[toolIndex + 1] : null;
---

<Layout title={`${tool.title} - ${t('site.name')}`}>
    <article class="max-w-3xl mx-auto">
        <header class="mb-8">
            <div class="flex items-center gap-3 mb-4">
                <div class="flex items-center gap-1">
                    {[...Array(5)].map((_, i) => (
                        <span key={i} class={i < Math.floor(tool.rating) ? "text-yellow-400 text-2xl" : "text-slate-300 dark:text-slate-600 text-2xl"}>★</span>
                    ))}
                </div>
                <span class="text-lg font-bold text-slate-600 dark:text-slate-400">{tool.rating}/5</span>
            </div>
            <div class="mb-4">
                <span class={`text-xs font-semibold px-3 py-1 rounded-full ${
                    tool.pricing === 'free' ? 'bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-200' :
                    tool.pricing === 'freemium' ? 'bg-purple-100 dark:bg-purple-900 text-purple-700 dark:text-purple-200' :
                    'bg-orange-100 dark:bg-orange-900 text-orange-700 dark:text-orange-200'
                }`}>
                    {tool.pricing.toUpperCase()}
                </span>
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-4">{tool.title}</h1>
            <div class="flex items-center gap-2 text-slate-500 dark:text-slate-400 text-sm">
                <time datetime={tool.date}>{tool.date}</time>
            </div>
        </header>

        <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 border border-slate-100 dark:border-slate-700 mb-8">
            <div class="prose dark:prose-invert max-w-none">
                <p class="text-lg leading-relaxed text-slate-700 dark:text-slate-300 mb-6">
                    {tool.snippet}
                </p>

                <h2 class="text-2xl font-bold mt-8 mb-4">Overview</h2>
                <p class="text-slate-700 dark:text-slate-300 mb-6">
                    This tool has been carefully reviewed based on its features, pricing, user experience, and value for soloprenuers. Our rating of {tool.rating}/5 reflects its effectiveness in helping solo entrepreneurs automate tasks and scale their businesses.
                </p>

                <h2 class="text-2xl font-bold mt-8 mb-4">Key Features</h2>
                <ul class="space-y-3 mb-6">
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 dark:text-blue-400 mt-1">✓</span>
                        <span>Intuitive user interface designed for non-technical users</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 dark:text-blue-400 mt-1">✓</span>
                        <span>Powerful automation capabilities for routine tasks</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 dark:text-blue-400 mt-1">✓</span>
                        <span>Reliable API and integration ecosystem</span>
                    </li>
                    <li class="flex items-start gap-3">
                        <span class="text-blue-600 dark:text-blue-400 mt-1">✓</span>
                        <span>Excellent customer support and documentation</span>
                    </li>
                </ul>

                <h2 class="text-2xl font-bold mt-8 mb-4">Pricing Breakdown</h2>
                <p class="text-slate-700 dark:text-slate-300 mb-6">
                    This tool offers a <strong>{tool.pricing}</strong> pricing model, making it accessible for soloprenuers at different stages of growth.
                    {tool.pricing === 'free' && 'The free plan provides essential features with no payment required.'}
                    {tool.pricing === 'freemium' && 'A free tier is available with upgrades for advanced features.'}
                    {tool.pricing === 'paid' && 'Premium features are available through paid subscription plans with various pricing tiers.'}
                </p>

                <h2 class="text-2xl font-bold mt-8 mb-4">Best For</h2>
                <p class="text-slate-700 dark:text-slate-300 mb-6">
                    This tool is ideal for soloprenuers who are looking to automate their workflows, save time on repetitive tasks, and scale their business without hiring additional team members. Whether you're a freelancer, consultant, or content creator, this tool can help you work smarter.
                </p>

                <h2 class="text-2xl font-bold mt-8 mb-4">Our Verdict</h2>
                <p class="text-slate-700 dark:text-slate-300 mb-6">
                    With its {tool.rating}/5 rating, this tool represents a solid investment for soloprenuers seeking to improve productivity and efficiency. The {tool.pricing} pricing model makes it accessible while delivering real value.
                </p>
            </div>
        </div>

        <!-- Navigation -->
        {(prevTool || nextTool) && (
            <div class="grid grid-cols-2 gap-4 mb-8">
                {prevTool ? (
                    <a href={`/${lang}/tools/${prevTool.slug}/`} class="p-4 rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors text-left">
                        <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">← Previous</div>
                        <div class="font-semibold line-clamp-2 hover:text-blue-600">{prevTool.title}</div>
                    </a>
                ) : (
                    <div />
                )}
                {nextTool ? (
                    <a href={`/${lang}/tools/${nextTool.slug}/`} class="p-4 rounded-xl border border-slate-200 dark:border-slate-700 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors text-right">
                        <div class="text-sm text-slate-500 dark:text-slate-400 mb-1">Next →</div>
                        <div class="font-semibold line-clamp-2 hover:text-blue-600">{nextTool.title}</div>
                    </a>
                ) : (
                    <div />
                )}
            </div>
        )}

        <!-- Back Link -->
        <div class="text-center">
            <a href={`/${lang}/tools/`} class="text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 font-medium">
                ← Back to {t('nav.tools')}
            </a>
        </div>
    </article>
</Layout>
