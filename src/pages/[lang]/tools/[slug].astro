---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { getToolReviews, getPageContent } from '../../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export async function getStaticPaths() {
  const langs: Array<'en' | 'ja' | 'zh'> = ['en', 'ja', 'zh'];
  const all: any[] = [];
  for (const l of langs) {
    const tools = await getToolReviews(l);
    tools.forEach((tool, idx) => {
      all.push({
        params: { lang: l, slug: tool.slug || tool.id },
        props: { tool, tools, idx },
      });
    });
  }
  return all;
}

interface Props {
  tool: any;
  tools: any[];
  idx: number;
}

const { tool, tools, idx } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prevTool = idx > 0 ? tools[idx - 1] : null;
const nextTool = idx < tools.length - 1 ? tools[idx + 1] : null;
const rating = Number(tool.rating) || 0;
const bodyHtml = await getPageContent(tool.id);
---

<Layout title={`${tool.title} - ${t('site.name')}`}>
  <section class="page-section">
    <div class="container">
      <article class="article fade-in">
        <header class="article-header">
          <div class="article-tags">
            {tool.category && <span class="card-badge">{tool.category}</span>}
            {tool.pricing && <span class="card-badge impact-notable">{tool.pricing}</span>}
          </div>
          <h1>{tool.title}</h1>
          <div class="article-meta">
            <span class="rating">
              {[0,1,2,3,4].map((s) => (
                <span class={s < Math.floor(rating) ? '' : 'star-empty'}>★</span>
              ))}
            </span>
            <span>{rating}/5</span>
            <span>·</span>
            <time datetime={tool.date}>{tool.date}</time>
          </div>
        </header>

        <div class="article-body">
          {tool.snippet && <p class="lead">{tool.snippet}</p>}
          {bodyHtml && <Fragment set:html={bodyHtml} />}
          {tool.url && (
            <p>
              <a href={tool.url} target="_blank" rel="noopener" style="color: var(--accent-cyan);">
                {lang === 'zh' ? '访问官网 →' : lang === 'ja' ? '公式サイトへ →' : 'Visit official site →'}
              </a>
            </p>
          )}
        </div>

        {(prevTool || nextTool) && (
          <div class="article-nav">
            {prevTool ? (
              <a href={`/${lang}/tools/${prevTool.slug || prevTool.id}/`} class="prev">
                <div class="nav-label">← {lang === 'zh' ? '上一个' : lang === 'ja' ? '前へ' : 'Previous'}</div>
                <div class="nav-title">{prevTool.title}</div>
              </a>
            ) : <div />}
            {nextTool ? (
              <a href={`/${lang}/tools/${nextTool.slug || nextTool.id}/`} class="next">
                <div class="nav-label">{lang === 'zh' ? '下一个' : lang === 'ja' ? '次へ' : 'Next'} →</div>
                <div class="nav-title">{nextTool.title}</div>
              </a>
            ) : <div />}
          </div>
        )}

        <div class="article-back">
          <a href={`/${lang}/tools/`}>← {t('nav.tools')}</a>
        </div>
      </article>
    </div>
  </section>
  <Footer lang={lang} />
</Layout>
