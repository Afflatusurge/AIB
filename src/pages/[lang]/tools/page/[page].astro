---
import Layout from '../../../../layouts/Layout.astro';
import Footer from '../../../../components/Footer.astro';
import ToolDeskPage from '../../../../components/list-pages/ToolDeskPage.astro';
import { getToolReviews } from '../../../../lib/notion';
import { getAdditionalPageParams, getPaginatedListing } from '../../../../lib/pagination';
import { useTranslations, getLangFromUrl } from '../../../../i18n/utils';

export async function getStaticPaths() {
  const langs = ['en', 'ja', 'zh'] as const;
  const paths = [];

  for (const lang of langs) {
    const toolReviews = await getToolReviews(lang);
    const { totalPages } = getPaginatedListing(toolReviews, 1);

    for (const params of getAdditionalPageParams(totalPages)) {
      paths.push({
        params: {
          lang,
          ...params,
        },
      });
    }
  }

  return paths;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPage = Number.parseInt(Astro.params.page || '1', 10);

const toolReviews = await getToolReviews(lang as 'en' | 'zh' | 'ja');
const listing = getPaginatedListing(toolReviews, currentPage);
---

<Layout title={`${t('nav.tools')} - ${t('site.name')}`}>
  <ToolDeskPage
    lang={lang}
    t={t}
    leadTool={listing.leadItem}
    tools={listing.entries}
    currentPage={listing.currentPage}
    totalPages={listing.totalPages}
  />
  <Footer lang={lang} />
</Layout>
