---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import CaseDeskPage from '../../../components/list-pages/CaseDeskPage.astro';
import { getCaseStudies } from '../../../lib/notion';
import { getPaginatedListing } from '../../../lib/pagination';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export function getStaticPaths() {
  return [
    { params: { lang: 'en' } },
    { params: { lang: 'ja' } },
    { params: { lang: 'zh' } },
  ];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const caseStudies = await getCaseStudies(lang as 'en' | 'zh' | 'ja');
const listing = getPaginatedListing(caseStudies, 1);
---

<Layout title={`${t('nav.cases')} - ${t('site.name')}`}>
  <CaseDeskPage
    lang={lang}
    t={t}
    leadCase={listing.leadItem}
    cases={listing.entries}
    currentPage={listing.currentPage}
    totalPages={listing.totalPages}
  />
  <Footer lang={lang} />
</Layout>
