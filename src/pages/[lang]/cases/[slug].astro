---
import Layout from '../../../layouts/Layout.astro';
import Footer from '../../../components/Footer.astro';
import { getCaseStudies, getPageContent } from '../../../lib/notion';
import { useTranslations, getLangFromUrl } from '../../../i18n/utils';

export async function getStaticPaths() {
  const langs: Array<'en' | 'ja' | 'zh'> = ['en', 'ja', 'zh'];
  const all: any[] = [];
  for (const l of langs) {
    const cases = await getCaseStudies(l);
    cases.forEach((cs, idx) => {
      all.push({
        params: { lang: l, slug: cs.slug || cs.id },
        props: { cs, cases, idx },
      });
    });
  }
  return all;
}

interface Props {
  cs: any;
  cases: any[];
  idx: number;
}

const { cs, cases, idx } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const prevCase = idx > 0 ? cases[idx - 1] : null;
const nextCase = idx < cases.length - 1 ? cases[idx + 1] : null;
const bodyHtml = await getPageContent(cs.id);
const relatedCases = cases.filter((item) => item.id !== cs.id).slice(0, 3);
const caseHeadingMatches = Array.from(bodyHtml.matchAll(/<h2>(.*?)<\/h2>/g));
const caseHeadingItems = caseHeadingMatches.map((match, i) => ({
  id: `section-${i + 1}`,
  title: match[1].replace(/<[^>]+>/g, ''),
}));
const caseHeadingQueue = [...caseHeadingItems];
const processedBodyHtml = caseHeadingMatches.length
  ? bodyHtml.replace(/<h2>/g, () => {
      const heading = caseHeadingQueue.shift();
      return heading ? `<h2 id="${heading.id}">` : '<h2>';
    })
  : bodyHtml;
const caseApplicability = cs.industry
  ? (lang === 'zh'
      ? `适合参考 ${cs.industry} 相关业务场景`
      : lang === 'ja'
        ? `${cs.industry}周辺の事業に応用しやすい`
        : `Especially relevant to ${cs.industry} operators`)
  : (lang === 'zh' ? '适合想用 AI 提高效率或创造新产品的人' : lang === 'ja' ? 'AIで効率化や新規商品化を目指す人向け' : 'Useful for builders exploring AI leverage');
const caseTakeaway = cs.takeaway || cs.snippet || (lang === 'zh' ? '真正值得看的不是故事本身，而是哪一段流程、判断或包装方式可以被复制。' : lang === 'ja' ? '注目すべきなのは物語そのものではなく、どの判断や運用が再利用できるかです。' : 'The useful layer is not the story itself, but which decision, workflow, or packaging move can be reused.');
const uiText = {
  problem: lang === 'zh' ? '问题' : lang === 'ja' ? '課題' : 'Problem',
  outcome: lang === 'zh' ? '结果' : lang === 'ja' ? '成果' : 'Outcome',
  applicableTo: lang === 'zh' ? '适用于' : lang === 'ja' ? '応用しやすい対象' : 'Applicable to',
  keyTakeaway: lang === 'zh' ? '关键结论' : lang === 'ja' ? '重要な学び' : 'Key takeaway',
  whatChanged: lang === 'zh' ? '发生了什么变化' : lang === 'ja' ? '何が変わったか' : 'What changed',
  whyThisCaseMatters: lang === 'zh' ? '为什么值得看' : lang === 'ja' ? 'なぜこの事例が重要か' : 'Why this case matters',
  caseSnapshot: lang === 'zh' ? '案例速览' : lang === 'ja' ? '事例概要' : 'Case snapshot',
  onThisPage: lang === 'zh' ? '本页目录' : lang === 'ja' ? 'このページ' : 'On this page',
  moreCases: lang === 'zh' ? '更多案例' : lang === 'ja' ? 'さらに読む事例' : 'More cases',
  continueReading: lang === 'zh' ? '继续阅读' : lang === 'ja' ? '続きを読む' : 'Continue reading',
} as const;
const summaryCards = [
  {
    label: uiText.problem,
    value: cs.problem || cs.industry || (lang === 'zh' ? '业务增长与效率' : lang === 'ja' ? '事業成長と効率化' : 'Growth and operations'),
  },
  {
    label: uiText.outcome,
    value: cs.revenue || (lang === 'zh' ? '重点不是绝对数字，而是这套做法是否明显改变了效率、产出或收入结构。' : lang === 'ja' ? '絶対額よりも、このやり方が効率、成果、収益構造をどう変えたかを見ると役立ちます。' : 'The useful signal is not the headline number alone, but whether the workflow materially changed efficiency, output, or revenue.'),
  },
  {
    label: uiText.applicableTo,
    value: cs.applicableTo || caseApplicability,
  },
  {
    label: uiText.keyTakeaway,
    value: cs.takeaway || caseTakeaway,
  },
];
const recommendationIntro = lang === 'zh'
  ? '沿着问题类型、结果和可复制经验继续看下去。'
  : lang === 'ja'
    ? '課題タイプ、成果、再現可能な学びで読み進められます。'
    : 'Continue by following adjacent problem types, outcomes, and reusable lessons.';
---

<Layout title={`${cs.title} - ${t('site.name')}`}>
  <section class="page-section">
    <div class="container">
      <article class="article-shell fade-in">
        <header class="article-hero">
          {cs.coverImage && (
            <div class="article-cover">
              <img src={cs.coverImage} alt={cs.title} loading="eager" />
            </div>
          )}
          <div class="article-tags">
            {cs.industry && <span class="card-badge">{cs.industry}</span>}
            {cs.revenue && <span class="card-badge impact-routine">{cs.revenue}</span>}
          </div>
          <h1>{cs.title}</h1>
          {cs.snippet && <p class="article-dek">{cs.snippet}</p>}
          <div class="article-meta">
            <time datetime={cs.date}>{cs.date}</time>
            {cs.tags && <><span>·</span><span>{cs.tags}</span></>}
          </div>
          <div class="article-lead-grid">
            <div class="article-lead-note">
              <p class="article-lead-label">{uiText.whatChanged}</p>
              <p>{cs.revenue || cs.takeaway || cs.snippet}</p>
            </div>
            <div class="article-lead-note alt">
              <p class="article-lead-label">{uiText.whyThisCaseMatters}</p>
              <p>{cs.applicableTo || cs.takeaway || caseApplicability}</p>
            </div>
          </div>
        </header>

        <div class="article-layout">
          <aside class="article-rail">
            <div class="rail-card">
              <p class="rail-label">{uiText.caseSnapshot}</p>
              <ul class="rail-list">
                <li><strong>{lang === 'zh' ? '栏目' : lang === 'ja' ? '欄' : 'Desk'}</strong><span>{t('nav.cases')}</span></li>
                <li><strong>{lang === 'zh' ? '领域' : lang === 'ja' ? '領域' : 'Industry'}</strong><span>{cs.industry || 'Business'}</span></li>
                <li><strong>{lang === 'zh' ? '问题类型' : lang === 'ja' ? '課題タイプ' : 'Problem type'}</strong><span>{cs.problemType || 'N/A'}</span></li>
                <li><strong>{lang === 'zh' ? '结果' : lang === 'ja' ? '結果' : 'Outcome'}</strong><span>{cs.revenue || 'N/A'}</span></li>
              </ul>
            </div>
            {caseHeadingItems.length > 0 && (
              <div class="rail-card">
                <p class="rail-label">{uiText.onThisPage}</p>
                <ul class="related-list">
                  {caseHeadingItems.map((item) => (
                    <li><a href={`#${item.id}`}>{item.title}</a></li>
                  ))}
                </ul>
              </div>
            )}
            {relatedCases.length > 0 && (
              <div class="rail-card">
                <p class="rail-label">{uiText.moreCases}</p>
                <ul class="related-list">
                  {relatedCases.map((item) => (
                    <li><a href={`/${lang}/cases/${item.slug || item.id}/`}>{item.title}</a></li>
                  ))}
                </ul>
              </div>
            )}
          </aside>

          <div class="article-column">
            <div class="summary-grid">
              {summaryCards.map((card) => (
                <section class="summary-card">
                  <p class="summary-label">{card.label}</p>
                  <div class="summary-value">{card.value}</div>
                </section>
              ))}
            </div>
            <div class="article-body">
              {processedBodyHtml && <Fragment set:html={processedBodyHtml} />}
            </div>
          </div>
        </div>

        {(prevCase || nextCase) && (
          <div class="article-nav">
            {prevCase ? (
              <a href={`/${lang}/cases/${prevCase.slug || prevCase.id}/`} class="prev">
                <div class="nav-label">← {lang === 'zh' ? '上一个' : lang === 'ja' ? '前へ' : 'Previous'}</div>
                <div class="nav-title">{prevCase.title}</div>
              </a>
            ) : <div />}
            {nextCase ? (
              <a href={`/${lang}/cases/${nextCase.slug || nextCase.id}/`} class="next">
                <div class="nav-label">{lang === 'zh' ? '下一个' : lang === 'ja' ? '次へ' : 'Next'} →</div>
                <div class="nav-title">{nextCase.title}</div>
              </a>
            ) : <div />}
          </div>
        )}

        {relatedCases.length > 0 && (
          <section class="article-recommendations">
            <div class="article-recommendations-head">
              <p class="article-recommendations-kicker">{uiText.continueReading}</p>
              <h2>{lang === 'zh' ? '更多案例拆解' : lang === 'ja' ? 'さらに読む事例解説' : 'More case breakdowns'}</h2>
              <p>{recommendationIntro}</p>
            </div>
            <div class="article-recommendations-grid">
              {relatedCases.map((item) => (
                <a href={`/${lang}/cases/${item.slug || item.id}/`} class="article-rec-card">
                  {item.coverImage && (
                    <div class="article-rec-cover">
                      <img src={item.coverImage} alt={item.title} loading="lazy" />
                    </div>
                  )}
                  <div class="article-rec-meta">
                    <span>{item.problemType || item.industry || 'Case'}</span>
                    <span>{item.revenue || item.tags || 'Outcome'}</span>
                  </div>
                  <h3>{item.title}</h3>
                  <p>{item.takeaway || item.snippet}</p>
                </a>
              ))}
            </div>
          </section>
        )}

        <div class="article-back">
          <a href={`/${lang}/cases/`}>← {t('nav.cases')}</a>
        </div>
      </article>
    </div>
  </section>
  <Footer lang={lang} />
</Layout>
