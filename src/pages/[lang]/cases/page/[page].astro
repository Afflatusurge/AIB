---
import Layout from '../../../../layouts/Layout.astro';
import Footer from '../../../../components/Footer.astro';
import CaseDeskPage from '../../../../components/list-pages/CaseDeskPage.astro';
import { getCaseStudies } from '../../../../lib/notion';
import { getAdditionalPageParams, getPaginatedListing } from '../../../../lib/pagination';
import { useTranslations, getLangFromUrl } from '../../../../i18n/utils';

export async function getStaticPaths() {
  const langs = ['en', 'ja', 'zh'] as const;
  const paths = [];

  for (const lang of langs) {
    const caseStudies = await getCaseStudies(lang);
    const { totalPages } = getPaginatedListing(caseStudies, 1);

    for (const params of getAdditionalPageParams(totalPages)) {
      paths.push({
        params: {
          lang,
          ...params,
        },
      });
    }
  }

  return paths;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPage = Number.parseInt(Astro.params.page || '1', 10);

const caseStudies = await getCaseStudies(lang as 'en' | 'zh' | 'ja');
const listing = getPaginatedListing(caseStudies, currentPage);
---

<Layout title={`${t('nav.cases')} - ${t('site.name')}`}>
  <CaseDeskPage
    lang={lang}
    t={t}
    leadCase={listing.leadItem}
    cases={listing.entries}
    currentPage={listing.currentPage}
    totalPages={listing.totalPages}
  />
  <Footer lang={lang} />
</Layout>
