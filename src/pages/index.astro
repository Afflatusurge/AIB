---
const target = '/en/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting...</title>
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <meta name="robots" content="noindex" />
    <link rel="canonical" href="https://aiandbusiness.com/en/" />
    <script is:inline define:vars={{ target }}>
      window.location.replace(target);
    </script>
    <style is:inline>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #f9f6ef;
        color: #1f1815;
        font-family: "Manrope", system-ui, sans-serif;
      }

      .redirect-fallback {
        font-size: 0.95rem;
      }

      .redirect-fallback a {
        color: inherit;
      }
    </style>
  </head>
  <body>
    <p class="redirect-fallback">
      Redirecting to <a href={target}>{target}</a>
    </p>
  </body>
</html>
