---
interface Props {
  lang: string;
  t: (key: string) => string;
}
const { lang, t } = Astro.props;

const cards = [
  {
    icon: '📡',
    iconClass: 'purple',
    size: 'large',
    title: { en: 'Daily Brief', zh: '每日简报', ja: 'デイリーブリーフ' },
    desc: { en: 'AI-curated daily intelligence feed. Model launches, funding rounds, policy changes, and solopreneur opportunities — filtered by impact.', zh: 'AI策展的每日情报。模型发布、融资动态、政策变化和创业机会，按影响力过滤排序。', ja: 'AI厳選のデイリーインテリジェンス。モデルリリース、資金調達、政策変更、起業チャンスを影響度で分類。' },
    tag: 'LIVE FEED',
    meta: { en: 'Updated today at 07:00 UTC', zh: '今日 07:00 UTC 更新', ja: '本日 07:00 UTC 更新' },
    href: `/${lang}/daily/`,
    delay: '',
  },
  {
    icon: '🔧',
    iconClass: 'blue',
    size: 'medium',
    title: { en: 'AI Tool Reviews', zh: 'AI工具评测', ja: 'AIツールレビュー' },
    desc: { en: 'Hands-on reviews with real benchmarks, pricing breakdowns, and workflow integration guides for solopreneurs.', zh: '实测评测：真实基准测试、定价分析和工作流集成指南。', ja: '実際のベンチマーク、価格分析、ワークフロー統合ガイド付きレビュー。' },
    tag: '50+ TOOLS',
    meta: { en: 'Updated weekly', zh: '每周更新', ja: '毎週更新' },
    href: `/${lang}/tools/`,
    delay: 'delay-1',
  },
  {
    icon: '📊',
    iconClass: 'green',
    size: 'third',
    title: { en: 'Case Studies', zh: '实战案例', ja: 'ケーススタディ' },
    desc: { en: 'Real solopreneurs building real businesses with AI. Revenue numbers, tech stacks, and breakdowns.', zh: '真实的AI创业者案例。收入数据、技术栈和详细拆解。', ja: '実在のAI起業家の事例。収益、技術スタック、詳細分析。' },
    tag: '30+ CASES',
    meta: null,
    href: `/${lang}/cases/`,
    delay: 'delay-1',
  },
  {
    icon: '⚡',
    iconClass: 'cyan',
    size: 'third',
    title: { en: 'Workflows', zh: '自动化流程', ja: 'ワークフロー' },
    desc: { en: 'Copy-paste automation blueprints. n8n, Zapier, and Make templates for solopreneur operations.', zh: '即用型自动化模板。n8n、Zapier、Make 工作流蓝图。', ja: 'コピペで使える自動化テンプレート。n8n、Zapier、Make対応。' },
    tag: 'COMING SOON',
    meta: null,
    href: '#',
    delay: 'delay-2',
  },
  {
    icon: '🧭',
    iconClass: 'amber',
    size: 'third',
    title: { en: 'Playbook', zh: '创业手册', ja: 'プレイブック' },
    desc: { en: 'From zero to revenue: structured guides for launching your AI solopreneur journey.', zh: '从零到盈利：AI一人公司创业结构化指南。', ja: 'ゼロから収益へ：AIソロ起業の構造化ガイド。' },
    tag: 'COMING SOON',
    meta: null,
    href: '#',
    delay: 'delay-3',
  },
];
---

<section class="section-block">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="section-label">// NAVIGATE</div>
    <h2 class="section-title">
      {lang === 'zh' ? 'AI一人公司操作系统' : lang === 'ja' ? 'AIソロプレナーOS' : 'Your AI Solopreneur OS'}
    </h2>
    <p class="section-desc">
      {lang === 'zh' ? '启动和发展AI一人公司所需的一切，组织成可执行的系统。' : lang === 'ja' ? 'AIソロビジネスに必要なすべてを、実行可能なシステムに。' : 'Everything you need to launch and grow a one-person AI business, organized into actionable systems.'}
    </p>

    <div class="bento-grid">
      {cards.map((card) => (
        <a href={card.href} class={`bento-card ${card.size} animate-in ${card.delay}`}>
          <div class={`bento-icon ${card.iconClass}`}>{card.icon}</div>
          <h3>{card.title[lang as keyof typeof card.title] || card.title.en}</h3>
          <p>{card.desc[lang as keyof typeof card.desc] || card.desc.en}</p>
          <div class="bento-meta">
            <span class="bento-tag">{card.tag}</span>
            {card.meta && <span class="bento-count">{card.meta[lang as keyof typeof card.meta] || card.meta.en}</span>}
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-purple);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .section-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 40px;
    max-width: 500px;
  }
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 16px;
  }
  .bento-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 28px;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .bento-card:hover {
    transform: translateY(-4px);
    background: var(--bg-card-hover);
    border-color: rgba(139,92,246,0.3);
    box-shadow: 0 20px 60px rgba(0,0,0,0.3);
  }
  .bento-card.large { grid-column: span 7; }
  .bento-card.medium { grid-column: span 5; }
  .bento-card.third { grid-column: span 4; }
  .bento-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    margin-bottom: 20px;
  }
  .bento-icon.purple { background: rgba(139,92,246,0.15); }
  .bento-icon.blue { background: rgba(59,130,246,0.15); }
  .bento-icon.cyan { background: rgba(6,182,212,0.15); }
  .bento-icon.green { background: rgba(16,185,129,0.15); }
  .bento-icon.amber { background: rgba(245,158,11,0.15); }
  .bento-card h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 8px;
  }
  .bento-card p {
    color: var(--text-secondary);
    font-size: 14px;
    line-height: 1.6;
    flex: 1;
  }
  .bento-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
  }
  .bento-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
    background: rgba(139,92,246,0.1);
    color: var(--accent-purple);
  }
  .bento-count {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .bento-card.large,
    .bento-card.medium,
    .bento-card.third { grid-column: span 12; }
  }
</style>