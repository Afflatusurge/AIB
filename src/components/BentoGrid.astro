---
interface ToolCard {
  title: string;
  slug: string;
  category?: string;
  pricing?: string;
  bestFor?: string;
}

interface CaseCard {
  title: string;
  slug: string;
  industry?: string;
  revenue?: string;
  problemType?: string;
}

interface PlaybookCard {
  title: string;
  slug: string;
  category?: string;
  bestFor?: string;
  outcome?: string;
  snippet?: string;
  useWhen?: string;
}

interface Props {
  lang: string;
  t: (key: string) => string;
  tools: ToolCard[];
  cases: CaseCard[];
  playbooks: PlaybookCard[];
}

const { lang, tools, cases, playbooks } = Astro.props;

const localizePlaybookCategory = (category?: string) => {
  if (!category) {
    return lang === 'zh' ? '实战手册' : lang === 'ja' ? 'プレイブック' : 'Playbook';
  }

  const labels: Record<string, { en: string; ja: string; zh: string }> = {
    Build: { en: 'Build', ja: '構築', zh: '搭建' },
    Media: { en: 'Media', ja: 'メディア', zh: '媒体' },
    Growth: { en: 'Growth', ja: '增长', zh: '增长' },
    Operations: { en: 'Operations', ja: '運営', zh: '运营' },
  };

  return labels[category]?.[lang as 'en' | 'ja' | 'zh'] ?? category;
};
---

<section class="section-block">
  <div class="container">
    <div class="section-label">// READING PATHS</div>
    <h2 class="section-title">
      {lang === 'zh'
        ? '继续往下读的三条路径'
        : lang === 'ja'
          ? 'サイトを深く読むための3つの入口'
          : 'Three deeper ways into the site'}
    </h2>
    <p class="section-desc">
      {lang === 'zh'
        ? 'Daily Brief 负责“发生了什么”，这三条路径则分别回答“什么值得评估”“什么已经跑通”“下一步该怎么做”。'
        : lang === 'ja'
          ? 'Daily Brief が「何が起きたか」を受け持つなら、この3つは「何を見極めるか」「何が実際に機能したか」「どう進めるか」を担当します。'
          : 'The daily brief handles what is new. These three desks help readers evaluate tools, learn from working cases, and move through a task step by step.'}
    </p>

    <div class="desk-grid">
      <article class="desk-card animate-in">
        <div class="desk-topline">
          <span class="desk-tag">01</span>
          <a href={`/${lang}/tools/`} class="desk-link">
            {lang === 'zh' ? '浏览工具评测' : lang === 'ja' ? 'ツールレビューを見る' : 'Browse tool reviews'}
          </a>
        </div>
        <div class="desk-intro">
          <h3>{lang === 'zh' ? '工具评测' : lang === 'ja' ? 'ツールレビュー' : 'Tool Reviews'}</h3>
          <p>
            {lang === 'zh'
              ? '不是工具目录，而是结构化评测：值不值得用、适合谁、怎样接进真实工作流。'
              : lang === 'ja'
                ? '単なるツール一覧ではなく、値段に見合うか、誰に向いているか、仕事の流れにどう入るかを見ます。'
                : 'Structured reviews that answer whether a tool is worth the money, who it serves, and how it fits a real workflow.'}
          </p>
        </div>
        <ul class="desk-list">
          {tools.length > 0 ? tools.map((tool) => (
            <li>
              <a href={`/${lang}/tools/${tool.slug}/`}>{tool.title}</a>
              <span>{tool.bestFor || tool.pricing || tool.category || 'AI'}</span>
            </li>
          )) : (
            <li class="empty-row">
              {lang === 'zh'
                ? '优先把最值得长期参考的工具页做成结构化评测。'
                : lang === 'ja'
                  ? 'まずは長く参照されるべきツールを、構造化レビューに整えます。'
                  : 'Start with the tools most worth turning into durable, structured reviews.'}
            </li>
          )}
        </ul>
      </article>

      <article class="desk-card animate-in delay-1">
        <div class="desk-topline">
          <span class="desk-tag">02</span>
          <a href={`/${lang}/cases/`} class="desk-link">
            {lang === 'zh' ? '查看案例分析' : lang === 'ja' ? 'ケースを見る' : 'View case studies'}
          </a>
        </div>
        <div class="desk-intro">
          <h3>{lang === 'zh' ? '案例分析' : lang === 'ja' ? 'ケーススタディ' : 'Case Studies'}</h3>
          <p>
            {lang === 'zh'
              ? '不再按行业堆内容，而是按问题组织案例，看清什么在增长、运营和产品化上真的跑通了。'
              : lang === 'ja'
                ? '業界で分けるのではなく、課題ごとに「何が実際に機能したか」を見せるケース集です。'
                : 'Problem-led cases that show what is actually working in growth, operations, and productization.'}
          </p>
        </div>
        <ul class="desk-list">
          {cases.length > 0 ? cases.map((item) => (
            <li>
              <a href={`/${lang}/cases/${item.slug}/`}>{item.title}</a>
              <span>{item.problemType || item.revenue || item.industry || (lang === 'zh' ? '案例' : lang === 'ja' ? 'ケース' : 'Case')}</span>
            </li>
          )) : (
            <li class="empty-row">
              {lang === 'zh'
                ? '把旧站里最强的行业页，改写成真正有决策价值的案例。'
                : lang === 'ja'
                  ? '旧サイトの強い業界ページを、意思決定に役立つケースへ再編集します。'
                  : 'Rewrite the strongest legacy industry pages into cases that actually help people decide.'}
            </li>
          )}
        </ul>
      </article>

      <article class="desk-card animate-in delay-2">
        <div class="desk-topline">
          <span class="desk-tag">03</span>
          <a href={`/${lang}/playbooks/`} class="desk-link">
            {lang === 'zh' ? '查看实战手册' : lang === 'ja' ? 'プレイブックを見る' : 'Open playbooks'}
          </a>
        </div>
        <div class="desk-intro">
          <h3>{lang === 'zh' ? '实战手册' : lang === 'ja' ? '実践プレイブック' : 'Playbooks'}</h3>
          <p>
            {lang === 'zh'
              ? '把评测、案例和日常信号串成一套可以直接照着执行的任务式指南。'
              : lang === 'ja'
                ? 'レビュー、事例、日々のシグナルを、実際に辿れるひとつの進め方へ組み直すタスク別ガイドです。'
                : 'Task-based guides that turn reviews, cases, and daily signals into one working stack you can actually follow.'}
          </p>
        </div>
        <ul class="desk-list">
          {playbooks.length > 0 ? playbooks.map((playbook) => (
            <li>
              <a href={`/${lang}/playbooks/${playbook.slug}/`}>{playbook.title}</a>
              <span>{localizePlaybookCategory(playbook.category)}</span>
            </li>
          )) : (
            <li class="empty-row">
              {lang === 'zh'
                ? '这里会放按任务组织的指南，把读者从“知道”带到“做到”。'
                : lang === 'ja'
                  ? 'ここでは、知ることから実行までをつなぐタスク別ガイドを並べます。'
                  : 'This is where task-based guides should connect what readers know with what they can actually do next.'}
            </li>
          )}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    line-height: 1;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 40px;
    max-width: 760px;
    line-height: 1.75;
  }
  .desk-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .desk-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 24px;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    flex-direction: column;
    min-height: 420px;
  }
  .desk-intro {
    margin-bottom: 18px;
  }
  .desk-card:hover {
    transform: translateY(-4px);
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
  }
  .desk-topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .desk-tag {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--accent);
  }
  .desk-link {
    font-size: 0.84rem;
    color: var(--text-muted);
  }
  .desk-card h3 {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    line-height: 0.98;
    margin-bottom: 12px;
  }
  .desk-card p {
    color: var(--text-secondary);
    font-size: 0.96rem;
    line-height: 1.75;
    margin-bottom: 0;
  }
  .desk-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .desk-list li {
    display: grid;
    gap: 6px;
    padding-top: 14px;
    border-top: 1px solid var(--border-subtle);
  }
  .desk-list a {
    color: var(--text-primary);
    font-weight: 700;
    line-height: 1.4;
  }
  .desk-list span,
  .empty-row {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .empty-row {
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .section-block { padding: 64px 0; }
    .desk-grid { grid-template-columns: 1fr; }
    .desk-card {
      min-height: unset;
      border-radius: 20px;
    }
  }
</style>
