---
interface ToolCard {
  title: string;
  slug: string;
  category?: string;
  pricing?: string;
  bestFor?: string;
}

interface CaseCard {
  title: string;
  slug: string;
  industry?: string;
  revenue?: string;
  problemType?: string;
}

interface PlaybookCard {
  title: string;
  slug: string;
  category?: string;
  bestFor?: string;
  outcome?: string;
  snippet?: string;
  useWhen?: string;
}

interface Props {
  lang: string;
  t: (key: string) => string;
  briefs: Array<{ title: string; slug: string; category?: string; commentary?: string }>;
  tools: ToolCard[];
  playbooks: PlaybookCard[];
}

const { lang, briefs, tools, playbooks } = Astro.props;

const localizePlaybookCategory = (category?: string) => {
  if (!category) {
    return lang === 'zh' ? '实战手册' : lang === 'ja' ? 'プレイブック' : 'Playbook';
  }

  const labels: Record<string, { en: string; ja: string; zh: string }> = {
    Build: { en: 'Build', ja: '構築', zh: '搭建' },
    Media: { en: 'Media', ja: 'メディア', zh: '媒体' },
    Growth: { en: 'Growth', ja: '增长', zh: '增长' },
    Operations: { en: 'Operations', ja: '運営', zh: '运营' },
  };

  return labels[category]?.[lang as 'en' | 'ja' | 'zh'] ?? category;
};
---

<section class="section-block">
  <div class="container">
    <div class="section-label">{lang === 'zh' ? '// 阅读路径' : lang === 'ja' ? '// 読み方' : '// READING PATHS'}</div>
    <h2 class="section-title">
      {lang === 'zh'
        ? '从你的需求开始'
        : lang === 'ja'
          ? '目的から選ぶ'
          : 'Start from what you need'}
    </h2>
    <p class="section-desc">
      {lang === 'zh'
        ? '看趋势、做决策、到实际执行。'
        : lang === 'ja'
          ? 'トレンド把握、意思決定、実行まで。'
          : 'News for awareness. Reviews for decisions. Playbooks for execution.'}
    </p>

    <div class="desk-grid">
      <article class="desk-card animate-in">
        <div class="desk-topline">
          <span class="desk-tag">01</span>
          <a href={`/${lang}/daily/`} class="desk-link">
            {lang === 'zh' ? '查看每日简报' : lang === 'ja' ? 'デイリーブリーフを見る' : 'Open daily brief'}
          </a>
        </div>
        <div class="desk-intro">
          <h3>{lang === 'zh' ? '每日简报' : lang === 'ja' ? 'デイリーブリーフ' : 'Daily Brief'}</h3>
          <p>
            {lang === 'zh'
              ? '掌握当天关键 AI 动态。'
              : lang === 'ja'
                ? '今日の重要な動きを把握。'
                : 'Track what matters today.'}
          </p>
        </div>
        <ul class="desk-list" data-live-bento-briefs>
          {briefs.length > 0 ? briefs.map((brief) => (
            <li>
              <a href={`/${lang}/daily/${brief.slug}/`}>{brief.title}</a>
              <span>{brief.commentary || brief.category || (lang === 'zh' ? '关键信号' : lang === 'ja' ? '重要シグナル' : 'Signal')}</span>
            </li>
          )) : (
            <li class="empty-row">
              {lang === 'zh'
                ? '接入内容后，这里会显示当天最值得看的更新。'
                : lang === 'ja'
                  ? '接続後、ここに今日の重要な更新が並びます。'
                  : 'The latest important updates will appear here once content is connected.'}
            </li>
          )}
        </ul>
      </article>

      <article class="desk-card animate-in delay-1">
        <div class="desk-topline">
          <span class="desk-tag">02</span>
          <a href={`/${lang}/tools/`} class="desk-link">
            {lang === 'zh' ? '浏览工具评测' : lang === 'ja' ? 'ツールレビューを見る' : 'Browse tool reviews'}
          </a>
        </div>
        <div class="desk-intro">
          <h3>{lang === 'zh' ? '工具评测' : lang === 'ja' ? 'ツールレビュー' : 'Tool Reviews'}</h3>
          <p>
            {lang === 'zh'
              ? '选择真正好用的工具。'
              : lang === 'ja'
                ? '最適なツールを選ぶ。'
                : 'Decide what to use.'}
          </p>
        </div>
        <ul class="desk-list">
          {tools.length > 0 ? tools.map((tool) => (
            <li>
              <a href={`/${lang}/tools/${tool.slug}/`}>{tool.title}</a>
              <span>{tool.bestFor || tool.pricing || tool.category || 'AI'}</span>
            </li>
          )) : (
            <li class="empty-row">
              {lang === 'zh'
                ? '这里会集中展示值得认真比较的工具。'
                : lang === 'ja'
                  ? 'ここには、比較して選ぶべきツールが並びます。'
                  : 'This is where the tools worth proper evaluation should appear.'}
            </li>
          )}
        </ul>
      </article>

      <article class="desk-card animate-in delay-2">
        <div class="desk-topline">
          <span class="desk-tag">03</span>
          <a href={`/${lang}/playbooks/`} class="desk-link">
            {lang === 'zh' ? '查看实战手册' : lang === 'ja' ? 'プレイブックを見る' : 'Open playbooks'}
          </a>
        </div>
        <div class="desk-intro">
          <h3>{lang === 'zh' ? '实战手册' : lang === 'ja' ? '実践プレイブック' : 'Playbooks'}</h3>
          <p>
            {lang === 'zh'
              ? '一步步完成任务。'
              : lang === 'ja'
                ? '実際に使って実行する。'
                : 'Execute step by step.'}
          </p>
        </div>
        <ul class="desk-list">
          {playbooks.length > 0 ? playbooks.map((playbook) => (
            <li>
              <a href={`/${lang}/playbooks/${playbook.slug}/`}>{playbook.title}</a>
              <span>{localizePlaybookCategory(playbook.category)}</span>
            </li>
          )) : (
            <li class="empty-row">
              {lang === 'zh'
                ? '这里会放按任务组织的指南，把读者从“知道”带到“做到”。'
                : lang === 'ja'
                  ? 'ここでは、知ることから実行までをつなぐタスク別ガイドを並べます。'
                  : 'This is where task-based guides should connect what readers know with what they can actually do next.'}
            </li>
          )}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .section-block { padding: 68px 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 4vw, 3.4rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    line-height: 1;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 40px;
    max-width: 760px;
    line-height: 1.75;
  }
  .desk-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }
  .desk-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 24px;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    flex-direction: column;
    min-height: 420px;
  }
  .desk-intro {
    margin-bottom: 18px;
  }
  .desk-card:hover {
    transform: translateY(-4px);
    background: var(--bg-card-hover);
    border-color: var(--border-hover);
  }
  .desk-topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .desk-tag {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    color: var(--accent);
  }
  .desk-link {
    font-size: 0.84rem;
    color: var(--text-muted);
  }
  .desk-card h3 {
    font-family: var(--font-display);
    font-size: 2.2rem;
    font-weight: 600;
    line-height: 0.98;
    margin-bottom: 12px;
  }
  .desk-card p {
    color: var(--text-secondary);
    font-size: 0.96rem;
    line-height: 1.75;
    margin-bottom: 0;
  }
  .desk-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }
  .desk-list li {
    display: grid;
    gap: 6px;
    padding-top: 14px;
    border-top: 1px solid var(--border-subtle);
  }
  .desk-list a {
    color: var(--text-primary);
    font-weight: 700;
    line-height: 1.4;
  }
  .desk-list span,
  .empty-row {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .empty-row {
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .section-block { padding: 54px 0; }
    .desk-grid { grid-template-columns: 1fr; }
    .desk-card {
      min-height: unset;
      border-radius: 20px;
    }
  }
</style>
