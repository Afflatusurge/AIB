---
interface Tool {
  title: string;
  snippet: string;
  rating: number;
  pricing: string;
  slug: string;
  date: string;
  category?: string;
}
interface Case {
  title: string;
  snippet: string;
  industry: string;
  revenue: string;
  slug: string;
  date: string;
}
interface Props {
  lang: string;
  t: (key: string) => string;
  tools: Tool[];
  cases: Case[];
}

const { lang, t, tools, cases } = Astro.props;

// Interleave tools and cases for variety
const items: Array<{ type: 'tool' | 'case'; data: any }> = [];
const maxLen = Math.max(tools.length, cases.length);
for (let i = 0; i < Math.min(maxLen, 3); i++) {
  if (i < tools.length) items.push({ type: 'tool', data: tools[i] });
  if (i < cases.length) items.push({ type: 'case', data: cases[i] });
}
const featured = items.slice(0, 3);
---

<section class="section-block">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="section-label">// FEATURED</div>
    <h2 class="section-title">
      {lang === 'zh' ? '本周精选' : lang === 'ja' ? '今週のピックアップ' : 'Top Picks This Week'}
    </h2>
    <p class="section-desc">
      {lang === 'zh' ? '为AI创业者精选的工具评测和实战案例。' : lang === 'ja' ? 'AIソロプレナーのために厳選されたツールとケーススタディ。' : 'Curated tools and case studies hand-picked for AI solopreneurs.'}
    </p>

    <div class="cards-grid">
      {featured.map((item, i) => (
        <a href={item.type === 'tool' ? `/${lang}/tools/${item.data.slug}/` : `/${lang}/cases/${item.data.slug}/`} class={`product-card animate-in ${i === 1 ? 'delay-1' : i === 2 ? 'delay-2' : ''}`}>
          <div class="card-header">
            <span class={`card-tag ${item.type}`}>
              {item.type === 'tool'
                ? (lang === 'zh' ? '工具评测' : lang === 'ja' ? 'ツールレビュー' : 'TOOL REVIEW')
                : (lang === 'zh' ? '案例分析' : lang === 'ja' ? 'ケーススタディ' : 'CASE STUDY')}
            </span>
            {item.type === 'tool' ? (
              <span class="card-rating">
                {[...Array(5)].map((_, s) => (
                  <span class={s < Math.floor(item.data.rating) ? 'star-on' : 'star-off'}>★</span>
                ))}
              </span>
            ) : (
              <span class="card-metric">{item.data.revenue}</span>
            )}
          </div>
          <h3>{item.data.title}</h3>
          <p class="desc">{item.data.snippet}</p>
          <div class="card-footer">
            <div class="card-footer-tags">
              {item.type === 'tool' ? (
                <>
                  <span class="card-footer-tag">{item.data.category || 'AI'}</span>
                  <span class="card-footer-tag">{item.data.pricing}</span>
                </>
              ) : (
                <>
                  <span class="card-footer-tag">{item.data.industry}</span>
                </>
              )}
            </div>
            <span class="card-arrow">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-purple);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .section-title {
    font-size: 32px;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 40px;
    max-width: 500px;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .product-card {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    padding: 24px;
    transition: all 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
  }
  .product-card:hover {
    transform: translateY(-4px);
    border-color: rgba(139,92,246,0.3);
    box-shadow: 0 16px 48px rgba(0,0,0,0.3);
  }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
  }
  .card-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 6px;
  }
  .card-tag.tool { background: rgba(59,130,246,0.12); color: var(--accent-blue); }
  .card-tag.case { background: rgba(16,185,129,0.12); color: var(--accent-green); }
  .card-rating {
    display: flex;
    gap: 2px;
    font-size: 12px;
  }
  .star-on { color: var(--accent-amber); }
  .star-off { color: var(--text-muted); }
  .card-metric {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    color: var(--accent-green);
  }
  .product-card h3 {
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .product-card .desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 16px;
  }
  .card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
  }
  .card-footer-tags {
    display: flex;
    gap: 6px;
  }
  .card-footer-tag {
    font-size: 11px;
    color: var(--text-muted);
    background: rgba(255,255,255,0.04);
    padding: 3px 8px;
    border-radius: 4px;
  }
  .card-arrow {
    color: var(--text-muted);
    font-size: 14px;
    transition: all 0.2s;
  }
  .product-card:hover .card-arrow {
    color: var(--accent-purple);
    transform: translateX(4px);
  }
  @media (max-width: 768px) {
    .cards-grid { grid-template-columns: 1fr; }
  }
</style>