---
interface Tool {
  title: string;
  snippet: string;
  rating: number;
  pricing: string;
  slug: string;
  date: string;
  category?: string;
  bestFor?: string;
  coverImage?: string;
}
interface Case {
  title: string;
  snippet: string;
  industry: string;
  revenue: string;
  slug: string;
  date: string;
  problemType?: string;
  coverImage?: string;
}
interface Props {
  lang: string;
  t: (key: string) => string;
  briefs: Array<{ title: string; slug: string; category?: string }>;
  tools: Tool[];
  cases: Case[];
}

const { lang, briefs, tools, cases } = Astro.props;

const leadTool = tools[0];
const leadCase = cases[0];
const leadToolDetails = [
  leadTool?.bestFor || (lang === 'zh' ? '适合对象待补齐' : lang === 'ja' ? '向いている読者を補完' : 'Audience fit'),
  leadTool?.pricing || (lang === 'zh' ? '定价与门槛' : lang === 'ja' ? '価格と導入ハードル' : 'Pricing and setup cost'),
  leadTool?.category || (lang === 'zh' ? '工作流位置' : lang === 'ja' ? 'ワークフロー上の位置' : 'Workflow role'),
].filter(Boolean).slice(0, 3);
const recentReads = [
  ...briefs.slice(0, 2).map((item) => ({ type: 'brief', href: `/${lang}/daily/${item.slug}/`, title: item.title, meta: item.category || 'Daily Brief' })),
  ...tools.slice(1, 3).map((item) => ({ type: 'tool', href: `/${lang}/tools/${item.slug}/`, title: item.title, meta: item.bestFor || item.pricing || item.category || 'Tool Review' })),
  ...cases.slice(1, 3).map((item) => ({ type: 'case', href: `/${lang}/cases/${item.slug}/`, title: item.title, meta: item.problemType || item.industry || 'Case Study' })),
].slice(0, 4);
---

<section class="section-block">
  <div class="container">
    <div class="section-label">{lang === 'zh' ? '// FEATURED READS' : lang === 'ja' ? '// FEATURED READS' : '// FEATURED READS'}</div>
    <h2 class="section-title">
      {lang === 'zh' ? '今天值得先读的内容' : lang === 'ja' ? '今日まず読むべき記事' : 'Featured reads for today'}
    </h2>
    <p class="section-desc">
      {lang === 'zh' ? '把最值得花时间的一篇评测、一则案例和几条延伸阅读放在一起，读者会更容易继续往下读。' : lang === 'ja' ? '時間をかけて読む価値のあるレビュー、ケース、関連読みに自然につながる並びにします。' : 'Pair one substantial review, one supporting case, and a few related reads so the front page feels edited rather than scattered.'}
    </p>

    <div class="feature-grid">
      <a href={leadTool ? `/${lang}/tools/${leadTool.slug}/` : `/${lang}/tools/`} class="lead-story animate-in">
        <div class={`lead-story-shell ${leadTool?.coverImage ? 'has-image' : ''}`}>
          <div class="lead-story-main">
            <span class="story-tag">{lang === 'zh' ? '主故事 / 工具评测' : lang === 'ja' ? '主役 / ツールレビュー' : 'Lead story / Tool review'}</span>
            <h3>{leadTool?.title || (lang === 'zh' ? '优先打造一篇足够代表站点气质的标杆评测' : lang === 'ja' ? 'サイトの空気感を代表する一本のレビューを先に' : 'Start with one flagship review that sets the tone for the whole site')}</h3>
            <p>{leadTool?.snippet || (lang === 'zh' ? '首页需要一篇足够“厚”的主文章，承担品牌解释、方法论和差异化感知。' : lang === 'ja' ? '厚みのある主役記事は、ブランドの違いと方法論を最短で伝えます。' : 'A substantial lead review helps explain the site’s judgment, standards, and point of view at a glance.')}</p>
            <div class="story-briefing">
              <p class="story-briefing-label">{lang === 'zh' ? '这篇会回答什么' : lang === 'ja' ? 'このレビューで分かること' : 'What this review clarifies'}</p>
              <ul class="story-points">
                {leadToolDetails.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </div>
          {leadTool?.coverImage && (
            <div class="lead-story-media">
              <div class="story-image-wrap feature">
                <img src={leadTool.coverImage} alt={leadTool.title} class="story-image" loading="lazy" />
              </div>
            </div>
          )}
        </div>
        <div class="story-meta">
          <span>{leadTool?.category || (lang === 'zh' ? '核心评测' : lang === 'ja' ? '基幹レビュー' : 'Cornerstone review')}</span>
          <span>{leadTool?.bestFor || leadTool?.pricing || (lang === 'zh' ? '定价 / 工作流 / 适配度' : lang === 'ja' ? '価格 / ワークフロー / 適合性' : 'Pricing / workflow / fit')}</span>
        </div>
      </a>

      <div class="side-column">
        <a href={leadCase ? `/${lang}/cases/${leadCase.slug}/` : `/${lang}/cases/`} class="support-story animate-in delay-1">
          {leadCase?.coverImage && (
            <div class="story-image-wrap compact">
              <img src={leadCase.coverImage} alt={leadCase.title} class="story-image" loading="lazy" />
            </div>
          )}
          <span class="story-tag alt">{lang === 'zh' ? '辅助故事 / 案例' : lang === 'ja' ? '補助 / ケース' : 'Supporting / Case study'}</span>
          <h4>{leadCase?.title || (lang === 'zh' ? '案例页应该回答“别人是怎么做成的”' : lang === 'ja' ? 'ケースは「他の人はどうやったか」に答える' : 'Case studies should answer how others actually made it work')}</h4>
          <p>{leadCase?.snippet || (lang === 'zh' ? '收入、效率、流程变化，比单纯“行业分类”更能让读者记住。' : lang === 'ja' ? '業界分類より、収益や効率、変化の物語の方が記憶に残ります。' : 'Revenue, workflow shifts, and practical outcomes are more memorable than broad industry buckets.')}</p>
          <div class="story-meta">
            <span>{leadCase?.problemType || leadCase?.industry || (lang === 'zh' ? '问题导向' : lang === 'ja' ? '課題起点' : 'Problem-led')}</span>
            <span>{leadCase?.revenue || (lang === 'zh' ? '结果导向案例' : lang === 'ja' ? '結果重視のケース' : 'Outcome-driven case')}</span>
          </div>
        </a>

        <div class="reads-panel animate-in delay-2">
          <div class="reads-head">
            <h4>{lang === 'zh' ? '继续阅读' : lang === 'ja' ? '続けて読む' : 'Recent reads'}</h4>
            <a href={`/${lang}/`}>{lang === 'zh' ? '回到首页' : lang === 'ja' ? 'ホームへ' : 'Home'}</a>
          </div>
          <ul>
            {recentReads.length > 0 ? recentReads.map((item) => (
              <li>
                <a href={item.href}>{item.title}</a>
                <span>{item.meta}</span>
              </li>
            )) : (
              <li class="reads-empty">{lang === 'zh' ? '内容同步后这里会显示最近更新。' : lang === 'ja' ? '同期後に最新記事が表示されます。' : 'Recent stories will appear here after content sync.'}</li>
            )}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3.8vw, 3.2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    line-height: 1;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 40px;
    max-width: 760px;
    line-height: 1.75;
  }
  .feature-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(320px, 0.72fr);
    gap: 20px;
    align-items: start;
  }
  .lead-story,
  .support-story,
  .reads-panel {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .lead-story {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
  }
  .lead-story-shell {
    display: grid;
    gap: 22px;
    align-items: start;
  }
  .lead-story-shell.has-image {
    grid-template-columns: minmax(0, 1.15fr) minmax(240px, 0.78fr);
  }
  .lead-story-main {
    display: grid;
    align-content: start;
  }
  .lead-story-media {
    height: 100%;
  }
  .lead-story:hover,
  .support-story:hover {
    transform: translateY(-4px);
    border-color: var(--border-hover);
  }
  .side-column {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 20px;
    height: 100%;
  }
  .story-tag {
    display: inline-flex;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .story-tag.alt {
    color: var(--accent-blue);
  }
  .story-image-wrap {
    margin: -8px -8px 18px;
    border-radius: 18px;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    background: linear-gradient(135deg, rgba(177, 90, 53, 0.12), rgba(61, 100, 120, 0.14));
  }
  .story-image-wrap.feature {
    margin: 0;
    aspect-ratio: 4 / 5;
    min-height: 100%;
  }
  .story-image-wrap.compact {
    aspect-ratio: 16 / 8.5;
  }
  .story-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .lead-story h3 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 4vw, 4rem);
    line-height: 0.96;
    letter-spacing: -0.05em;
    margin-bottom: 16px;
  }
  .lead-story p,
  .support-story p {
    color: var(--text-secondary);
    font-size: 0.98rem;
    line-height: 1.75;
    margin-bottom: 22px;
  }
  .story-briefing {
    margin: 0 0 22px;
    padding: 16px 0 0;
    border-top: 1px solid var(--border-subtle);
  }
  .story-briefing-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    margin-bottom: 10px;
  }
  .story-points {
    list-style: none;
    display: grid;
    gap: 8px;
    padding: 0;
    margin: 0;
  }
  .story-points li {
    color: var(--text-secondary);
    font-size: 0.92rem;
    line-height: 1.5;
    padding-left: 14px;
    position: relative;
  }
  .story-points li::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--accent);
    position: absolute;
    left: 0;
    top: 0.62rem;
  }
  .support-story h4,
  .reads-head h4 {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 12px;
  }
  .story-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-family: var(--font-mono);
    color: var(--text-muted);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .reads-panel {
    min-height: 100%;
    display: flex;
    flex-direction: column;
  }
  .reads-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 16px;
  }
  .reads-head a {
    font-size: 0.82rem;
    color: var(--accent);
  }
  .reads-panel ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    flex: 1;
  }
  .reads-panel li {
    display: grid;
    gap: 6px;
    padding: 14px 0;
    border-top: 1px solid var(--border-subtle);
  }
  .reads-panel li:first-child {
    border-top: 0;
    padding-top: 0;
  }
  .reads-panel li a {
    font-weight: 700;
    line-height: 1.45;
  }
  .reads-panel li span,
  .reads-empty {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  @media (max-width: 768px) {
    .feature-grid { grid-template-columns: 1fr; }
    .lead-story-shell.has-image {
      grid-template-columns: 1fr;
    }
    .lead-story,
    .support-story,
    .reads-panel {
      border-radius: 20px;
    }
    .lead-story h3,
    .support-story h4,
    .reads-head h4 {
      font-size: 2rem;
    }
  }
</style>
