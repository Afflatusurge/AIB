---
interface Props {
  lang: string;
  t: (key: string) => string;
  leadBrief?: { title: string; slug?: string; category?: string; commentary?: string };
  leadTool?: { title: string; slug?: string; pricing?: string; bestFor?: string };
  leadCase?: { title: string; slug?: string; industry?: string; problemType?: string };
}
const { lang, t, leadBrief, leadTool, leadCase } = Astro.props;
const editorialTimeZone = 'America/Los_Angeles';
const editorialLocale = lang === 'zh' ? 'zh-CN' : lang === 'ja' ? 'ja-JP' : 'en-US';
const editionDate = new Intl.DateTimeFormat(editorialLocale, {
  timeZone: editorialTimeZone,
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(new Date());
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy animate-in">
      <p class="hero-kicker">
        {lang === 'zh' ? 'AI-FIRST MEDIA FOR SOLO BUILDERS' : lang === 'ja' ? 'AI-FIRST MEDIA FOR SOLO BUILDERS' : 'AI-FIRST MEDIA FOR SOLO BUILDERS'}
      </p>
      <h1 class={`hero-title animate-in delay-1 ${lang === 'en' ? '' : 'is-cjk'} ${lang === 'ja' ? 'is-ja' : ''}`}>
        {lang === 'zh' ? (
          <>写给想把 AI 生意做成的人。<span>一份单人公司指南。</span></>
        ) : lang === 'ja' ? (
          <>AIのノイズを、<span>ビジネスのシグナルへ</span></>
        ) : (
          <>AI, filtered for <span>decisions and execution.</span></>
        )}
      </h1>
      <p class="hero-sub animate-in delay-2">
        {lang === 'zh'
          ? '筛选重要信息，理解趋势，并一步步落地执行。'
          : lang === 'ja'
            ? '重要な情報だけを抽出し、理解し、実行する。'
            : 'Cut through the noise. Understand what matters. Apply it step by step.'}
      </p>
      <div class="hero-cta animate-in delay-3">
        <a href={`/${lang}/daily/`} class="btn-primary">
          {lang === 'zh' ? '查看每日简报' : lang === 'ja' ? 'デイリーブリーフを見る' : 'Start with Daily Brief'}
        </a>
        <a href={`/${lang}/playbooks/`} class="btn-secondary">
          {lang === 'zh' ? '浏览实战指南' : lang === 'ja' ? 'プレイブックを見る' : 'Explore Playbooks'}
        </a>
      </div>
    </div>

    <aside class="edition-panel animate-in delay-2">
      <div class="edition-topline">
        <span class="edition-pill">
          {lang === 'zh' ? '今日版面' : lang === 'ja' ? '本日の版' : "Today's edition"}
        </span>
        <span class="edition-date">
          {editionDate}
        </span>
      </div>
      <div class="edition-list">
        <a href={`/${lang}/daily/${leadBrief?.slug || ''}`} class={`edition-item ${leadBrief ? '' : 'is-disabled'}`}>
          <span class="edition-label">{t('nav.daily')}</span>
          <strong>{leadBrief?.title || (lang === 'zh' ? '等待 Notion 内容同步' : lang === 'ja' ? 'Notion同期を待機中' : 'Waiting for Notion content')}</strong>
          <span class="edition-meta">{leadBrief?.commentary || leadBrief?.category || (lang === 'zh' ? '每日信号' : lang === 'ja' ? 'デイリーシグナル' : 'Daily signals')}</span>
        </a>
        <a href={`/${lang}/tools/${leadTool?.slug || ''}`} class={`edition-item ${leadTool ? '' : 'is-disabled'}`}>
          <span class="edition-label">{t('nav.tools')}</span>
          <strong>{leadTool?.title || (lang === 'zh' ? '优先补齐 6 篇核心评测' : lang === 'ja' ? 'まず6本の基幹レビューを' : 'Prioritize the first six cornerstone reviews')}</strong>
          <span class="edition-meta">{leadTool?.bestFor || leadTool?.pricing || (lang === 'zh' ? '结构化实测、定价和工作流' : lang === 'ja' ? '実測、価格、ワークフロー' : 'Benchmarks, pricing, and workflow fit')}</span>
        </a>
        <a href={`/${lang}/cases/${leadCase?.slug || ''}`} class={`edition-item ${leadCase ? '' : 'is-disabled'}`}>
          <span class="edition-label">{t('nav.cases')}</span>
          <strong>{leadCase?.title || (lang === 'zh' ? '把行业分类重组为问题导向案例' : lang === 'ja' ? '業界別を課題別ケースへ再編' : 'Reframe industry pages into problem-led cases')}</strong>
          <span class="edition-meta">{leadCase?.problemType || leadCase?.industry || (lang === 'zh' ? '增长、自动化、产品化、一人公司' : lang === 'ja' ? '成長、自動化、商品化、ひとり起業' : 'Growth, automation, productization, solo stories')}</span>
        </a>
      </div>
      <p class="edition-note">
        {lang === 'zh'
          ? '先从一条 brief、一篇评测、一个案例进入，就能很快读懂这个站。'
          : lang === 'ja'
            ? 'まずはブリーフ、レビュー、ケースを1本ずつ読むと、このサイトの全体像がつかめます。'
            : 'Start with one brief, one review, and one case study to understand the shape of the site quickly.'}
      </p>
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 64px 0 72px;
  }
  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.78fr);
    gap: 32px;
    align-items: end;
  }
  .hero-copy {
    max-width: 760px;
  }
  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 8vw, 7.2rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.92;
    margin-bottom: 24px;
    color: var(--text-primary);
  }
  .hero-title.is-cjk {
    line-height: 1.04;
    letter-spacing: -0.03em;
  }
  .hero-title.is-ja {
    font-size: clamp(3.2rem, 6.9vw, 6.4rem);
    line-height: 1.08;
  }
  .hero-title span {
    color: var(--accent);
  }
  .hero-sub {
    font-size: 1.08rem;
    color: var(--text-secondary);
    max-width: 44rem;
    margin: 0 0 34px;
    line-height: 1.75;
  }
  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: var(--text-primary);
    color: var(--bg-primary);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(32, 27, 24, 0.14);
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: var(--bg-card);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid var(--border-subtle);
  }
  .btn-secondary:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
  }
  .edition-panel {
    background: rgba(251, 248, 241, 0.82);
    border: 1px solid var(--border-subtle);
    border-radius: 28px;
    padding: 24px;
    box-shadow: 0 16px 40px rgba(32, 27, 24, 0.05);
  }
  .edition-topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .edition-pill {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .edition-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .edition-list {
    display: grid;
    gap: 12px;
  }
  .edition-item {
    display: grid;
    gap: 6px;
    padding: 16px 0;
    border-top: 1px solid var(--border-subtle);
    color: inherit;
    text-decoration: none;
  }
  .edition-item strong {
    font-size: 1.02rem;
    line-height: 1.35;
  }
  .edition-item:hover strong {
    color: var(--accent);
  }
  .edition-item.is-disabled {
    pointer-events: none;
  }
  .edition-label,
  .edition-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .edition-note {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 40px 0 56px;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 0 18px;
    }
    .hero-title {
      font-size: 3.5rem;
    }
    .hero-title.is-cjk {
      line-height: 1.08;
    }
    .hero-sub {
      font-size: 1rem;
    }
    .edition-panel {
      border-radius: 22px;
      padding: 20px;
    }
  }
</style>
