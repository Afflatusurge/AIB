---
interface Props {
  lang: string;
  t: (key: string) => string;
  leadBrief?: { title: string; slug?: string; category?: string; commentary?: string };
  leadTool?: { title: string; slug?: string; pricing?: string; bestFor?: string };
  leadCase?: { title: string; slug?: string; industry?: string; problemType?: string };
}
const { lang, t, leadBrief, leadTool, leadCase } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy animate-in">
      <p class="hero-kicker">
        {lang === 'zh' ? 'AI-FIRST MEDIA FOR SOLO BUILDERS' : lang === 'ja' ? 'AI-FIRST MEDIA FOR SOLO BUILDERS' : 'AI-FIRST MEDIA FOR SOLO BUILDERS'}
      </p>
      <h1 class={`hero-title animate-in delay-1 ${lang === 'en' ? '' : 'is-cjk'}`}>
        {lang === 'zh' ? (
          <>写给想把 AI 生意做成的人。<span>一份单人公司指南。</span></>
        ) : lang === 'ja' ? (
          <>ひとりでAIビジネスを形にしたい人へ。<span>ひとり会社のためのガイド。</span></>
        ) : (
          <>An editorial guide to building an <span>AI-first business of one.</span></>
        )}
      </h1>
      <p class="hero-sub animate-in delay-2">
        {lang === 'zh'
          ? '不是把工具、新闻和案例堆成目录，而是帮你判断今天该看什么、该试什么、下一步该怎么做。'
          : lang === 'ja'
            ? 'ニュースやツールや事例を並べるだけではなく、今日どれを見るべきか、何を試すべきか、次にどう動くかまで判断しやすくします。'
            : 'Less directory, more newsroom. We filter the noise into daily briefs, practical tool reviews, and case studies built for AI solopreneurs.'}
      </p>
      <div class="hero-cta animate-in delay-3">
        <a href={`/${lang}/daily/`} class="btn-primary">
          {lang === 'zh' ? '阅读今日简报' : lang === 'ja' ? '今日のブリーフを読む' : "Read today's brief"}
        </a>
        <a href={`/${lang}/cases/`} class="btn-secondary">
          {lang === 'zh' ? '查看案例库' : lang === 'ja' ? 'ケースを探す' : 'Browse case studies'}
        </a>
      </div>
      <dl class="hero-stats animate-in delay-4">
        <div class="hero-stat">
          <dt>{lang === 'zh' ? '内容支柱' : lang === 'ja' ? '柱' : 'Pillars'}</dt>
          <dd>3</dd>
        </div>
        <div class="hero-stat">
          <dt>{lang === 'zh' ? '更新节奏' : lang === 'ja' ? '更新頻度' : 'Cadence'}</dt>
          <dd>{lang === 'zh' ? '每日 / 每周' : lang === 'ja' ? '毎日 / 毎週' : 'Daily / Weekly'}</dd>
        </div>
        <div class="hero-stat">
          <dt>{lang === 'zh' ? '语言' : lang === 'ja' ? '言語' : 'Languages'}</dt>
          <dd>EN / JA / ZH</dd>
        </div>
      </dl>
    </div>

    <aside class="edition-panel animate-in delay-2">
      <div class="edition-topline">
        <span class="edition-pill">
          {lang === 'zh' ? '今日版面' : lang === 'ja' ? '本日の版' : "Today's edition"}
        </span>
        <span class="edition-date">
          {new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : lang === 'ja' ? 'ja-JP' : 'en-US', {
            month: 'short',
            day: 'numeric',
            year: 'numeric',
          }).format(new Date())}
        </span>
      </div>
      <div class="edition-list">
        <a href={`/${lang}/daily/${leadBrief?.slug || ''}`} class={`edition-item ${leadBrief ? '' : 'is-disabled'}`}>
          <span class="edition-label">{t('nav.daily')}</span>
          <strong>{leadBrief?.title || (lang === 'zh' ? '等待 Notion 内容同步' : lang === 'ja' ? 'Notion同期を待機中' : 'Waiting for Notion content')}</strong>
          <span class="edition-meta">{leadBrief?.commentary || leadBrief?.category || (lang === 'zh' ? '每日信号' : lang === 'ja' ? 'デイリーシグナル' : 'Daily signals')}</span>
        </a>
        <a href={`/${lang}/tools/${leadTool?.slug || ''}`} class={`edition-item ${leadTool ? '' : 'is-disabled'}`}>
          <span class="edition-label">{t('nav.tools')}</span>
          <strong>{leadTool?.title || (lang === 'zh' ? '优先补齐 6 篇核心评测' : lang === 'ja' ? 'まず6本の基幹レビューを' : 'Prioritize the first six cornerstone reviews')}</strong>
          <span class="edition-meta">{leadTool?.bestFor || leadTool?.pricing || (lang === 'zh' ? '结构化实测、定价和工作流' : lang === 'ja' ? '実測、価格、ワークフロー' : 'Benchmarks, pricing, and workflow fit')}</span>
        </a>
        <a href={`/${lang}/cases/${leadCase?.slug || ''}`} class={`edition-item ${leadCase ? '' : 'is-disabled'}`}>
          <span class="edition-label">{t('nav.cases')}</span>
          <strong>{leadCase?.title || (lang === 'zh' ? '把行业分类重组为问题导向案例' : lang === 'ja' ? '業界別を課題別ケースへ再編' : 'Reframe industry pages into problem-led cases')}</strong>
          <span class="edition-meta">{leadCase?.problemType || leadCase?.industry || (lang === 'zh' ? '增长、自动化、产品化、一人公司' : lang === 'ja' ? '成長、自動化、商品化、ひとり起業' : 'Growth, automation, productization, solo stories')}</span>
        </a>
      </div>
      <p class="edition-note">
        {lang === 'zh'
          ? '首页应该像编辑精选页，帮助读者在 30 秒内理解站点价值和最新入口。'
          : lang === 'ja'
            ? 'トップページは編集部の目線で、30秒で読む価値と入口が伝わるべきです。'
            : 'The homepage should work like a front page: clear value, clear sections, clear next read in under 30 seconds.'}
      </p>
    </aside>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 64px 0 72px;
  }
  .hero-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    width: 100%;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.78fr);
    gap: 32px;
    align-items: end;
  }
  .hero-copy {
    max-width: 760px;
  }
  .hero-kicker {
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3.6rem, 8vw, 7.2rem);
    font-weight: 600;
    letter-spacing: -0.05em;
    line-height: 0.92;
    margin-bottom: 24px;
    color: var(--text-primary);
  }
  .hero-title.is-cjk {
    line-height: 1.04;
    letter-spacing: -0.03em;
  }
  .hero-title span {
    color: var(--accent);
  }
  .hero-sub {
    font-size: 1.08rem;
    color: var(--text-secondary);
    max-width: 44rem;
    margin: 0 0 34px;
    line-height: 1.75;
  }
  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 36px;
  }
  .hero-stats {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hero-stat {
    min-width: 170px;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
  }
  .hero-stat dt {
    font-size: 0.74rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin-bottom: 10px;
  }
  .hero-stat dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.8rem;
    line-height: 1;
    color: var(--text-primary);
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: var(--text-primary);
    color: var(--bg-primary);
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(32, 27, 24, 0.14);
  }
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 22px;
    background: var(--bg-card);
    color: var(--text-primary);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid var(--border-subtle);
  }
  .btn-secondary:hover {
    border-color: var(--border-hover);
    background: var(--bg-card-hover);
  }
  .edition-panel {
    background: rgba(251, 248, 241, 0.82);
    border: 1px solid var(--border-subtle);
    border-radius: 28px;
    padding: 24px;
    box-shadow: 0 16px 40px rgba(32, 27, 24, 0.05);
  }
  .edition-topline {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }
  .edition-pill {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .edition-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-muted);
  }
  .edition-list {
    display: grid;
    gap: 12px;
  }
  .edition-item {
    display: grid;
    gap: 6px;
    padding: 16px 0;
    border-top: 1px solid var(--border-subtle);
    color: inherit;
    text-decoration: none;
  }
  .edition-item strong {
    font-size: 1.02rem;
    line-height: 1.35;
  }
  .edition-item:hover strong {
    color: var(--accent);
  }
  .edition-item.is-disabled {
    pointer-events: none;
  }
  .edition-label,
  .edition-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .edition-note {
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--border-subtle);
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .hero {
      padding: 40px 0 56px;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 0 18px;
    }
    .hero-title {
      font-size: 3.5rem;
    }
    .hero-title.is-cjk {
      line-height: 1.08;
    }
    .hero-sub {
      font-size: 1rem;
    }
    .hero-stat {
      min-width: min(44%, 180px);
    }
    .edition-panel {
      border-radius: 22px;
      padding: 20px;
    }
  }
</style>
