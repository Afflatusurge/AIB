---
interface Props {
  lang: string;
}
const { lang } = Astro.props;
---

<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <div class="footer-copy">
        <strong>{lang === 'zh' ? 'AI一人公司指南' : lang === 'ja' ? 'AIソロプレナーガイド' : 'AI Solopreneur Guide'}</strong>
        <p>
          © {new Date().getFullYear()} AiandBusiness.com
          {lang === 'zh' ? ' 一个关于 AI 一人公司、工具评测与真实案例的内容型网站。' : lang === 'ja' ? ' AIソロプレナーのためのデイリーブリーフ、レビュー、ケーススタディ。' : ' Daily briefs, tool reviews, and case studies for AI-first independent builders.'}
        </p>
      </div>
      <div class="footer-links">
        <a href={`/${lang}/daily/`}>{lang === 'zh' ? '每日简报' : lang === 'ja' ? 'デイリーブリーフ' : 'Daily Brief'}</a>
        <a href={`/${lang}/tools/`}>{lang === 'zh' ? '工具评测' : lang === 'ja' ? 'ツールレビュー' : 'Tool Reviews'}</a>
        <a href={`/${lang}/playbooks/`}>{lang === 'zh' ? '实战指南' : lang === 'ja' ? 'プレイブック' : 'Playbooks'}</a>
        <a href={`/${lang}/cases/`}>{lang === 'zh' ? '案例分析' : lang === 'ja' ? 'ケーススタディ' : 'Case Studies'}</a>
        <a href="https://docs.aiandbusiness.com/" target="_blank" rel="noopener noreferrer">
          {lang === 'zh' ? '资料库' : lang === 'ja' ? 'ライブラリ' : 'Library'}
        </a>
        <a href={`/${lang}/about/`}>{lang === 'zh' ? '关于' : lang === 'ja' ? 'About' : 'About'}</a>
        <a href={`/${lang}/terms/`}>{lang === 'zh' ? '服务条款' : lang === 'ja' ? '利用規約' : 'Terms of Service'}</a>
        <button type="button" class="footer-link-button" data-open-consent>
          {lang === 'zh' ? '隐私设置' : lang === 'ja' ? 'Cookie設定' : 'Cookie Settings'}
        </button>
      </div>
    </div>
  </div>
</footer>

<script is:inline>
  (() => {
    document.querySelectorAll('[data-open-consent]').forEach((button) => {
      button.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('aib:open-consent-settings'));
      });
    });
  })();
</script>

<style>
  .footer {
    border-top: 1px solid var(--border-subtle);
    padding: 48px 0;
    margin-top: 20px;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 20px;
  }
  .footer-copy strong {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.03em;
  }
  .footer-copy p {
    font-size: 0.86rem;
    color: var(--text-muted);
    margin-top: 8px;
    max-width: 34rem;
    line-height: 1.7;
  }
  .footer-links {
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
  }
  .footer-links a {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
  }
  .footer-link-button {
    font-size: 0.82rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-family: var(--font-mono);
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
  }
  .footer-links a:hover { color: var(--text-primary); }
  .footer-link-button:hover { color: var(--text-primary); }
  @media (max-width: 768px) {
    .footer-inner { flex-direction: column; gap: 16px; align-items: start; }
  }
</style>
