---
interface Props {
  lang: string;
}
const { lang } = Astro.props;
---

<section class="section-block">
  <div class="container">
    <div class="newsletter animate-in">
      <div class="newsletter-copy">
        <p class="newsletter-kicker">
          {lang === 'zh' ? 'NEWSLETTER' : lang === 'ja' ? 'NEWSLETTER' : 'NEWSLETTER'}
        </p>
        <h2>
          {lang === 'zh' ? '如果首页像编辑部，邮件就该像每日头版。' : lang === 'ja' ? 'トップが編集部なら、メールは毎日の一面であるべき。' : 'If the site feels like a newsroom, the email should feel like its daily front page.'}
        </h2>
        <p class="sub">
          {lang === 'zh' ? '这里先保留订阅区，但视觉上更像一则编辑邀请，而不是 SaaS 表单模块。' : lang === 'ja' ? 'ここはSaaSのフォームではなく、編集部からの招待のように見せます。' : 'Keep the email CTA, but style it like an editorial invitation rather than a generic product signup block.'}
        </p>
      </div>
      <form class="newsletter-form" onsubmit="return false;">
        <input type="email" placeholder={lang === 'zh' ? '输入邮箱，接收每日 brief' : lang === 'ja' ? 'メールアドレスを入力' : 'Enter your email for the daily brief'} />
        <button class="btn-primary" type="submit">
          {lang === 'zh' ? '加入收件箱版' : lang === 'ja' ? '購読する' : 'Join the inbox edition'}
        </button>
      </form>
      <div class="newsletter-features">
        <div class="newsletter-feature">
          <span class="check">01</span>
          {lang === 'zh' ? '每天 3-5 条精编内容' : lang === 'ja' ? '毎日3〜5本の厳選' : '3-5 curated items each day'}
        </div>
        <div class="newsletter-feature">
          <span class="check">02</span>
          {lang === 'zh' ? '附上为什么值得关注' : lang === 'ja' ? 'なぜ重要かを添える' : 'Why it matters for your business'}
        </div>
        <div class="newsletter-feature">
          <span class="check">03</span>
          {lang === 'zh' ? '工具与案例会定期串联' : lang === 'ja' ? 'ツールと事例を横断' : 'Cross-links to reviews and cases'}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .newsletter {
    position: relative;
    border-radius: 28px;
    padding: 40px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(251, 248, 241, 0.9), rgba(239, 229, 214, 0.9));
    border: 1px solid var(--border-subtle);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.9fr);
    gap: 28px;
  }
  .newsletter::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 15% 0%, rgba(177, 90, 53, 0.08) 0%, transparent 52%);
    pointer-events: none;
  }
  .newsletter-copy {
    position: relative;
  }
  .newsletter-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 14px;
  }
  .newsletter h2 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.6rem);
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.04em;
    line-height: 0.98;
    position: relative;
  }
  .newsletter .sub {
    color: var(--text-secondary);
    font-size: 0.98rem;
    margin-bottom: 0;
    position: relative;
    line-height: 1.75;
  }
  .newsletter-form {
    display: grid;
    gap: 12px;
    align-content: start;
    position: relative;
  }
  .newsletter-form input {
    flex: 1;
    padding: 14px 20px;
    background: rgba(255,255,255,0.52);
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    color: var(--text-primary);
    font-size: 14px;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.2s;
  }
  .newsletter-form input:focus { border-color: var(--border-hover); }
  .newsletter-form input::placeholder { color: var(--text-muted); }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    justify-content: center;
    padding: 14px 22px;
    background: var(--text-primary);
    color: var(--bg-primary);
    font-weight: 700;
    font-size: 15px;
    border-radius: 999px;
    text-decoration: none;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    white-space: nowrap;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 30px rgba(32, 27, 24, 0.14);
  }
  .newsletter-features {
    display: grid;
    gap: 12px;
    position: relative;
    grid-column: 2;
  }
  .newsletter-feature {
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: start;
    gap: 10px;
    font-size: 13px;
    color: var(--text-secondary);
    padding-top: 12px;
    border-top: 1px solid var(--border-subtle);
  }
  .check {
    color: var(--accent);
    font-weight: 700;
    font-family: var(--font-mono);
  }
  @media (max-width: 768px) {
    .newsletter {
      grid-template-columns: 1fr;
      padding: 28px 22px;
      border-radius: 22px;
    }
    .newsletter-features {
      grid-column: auto;
    }
  }
</style>
