---
interface Props {
  lang: string;
}
const { lang } = Astro.props;
---

<section class="section-block">
  <div class="max-w-[1200px] mx-auto px-6">
    <div class="newsletter animate-in">
      <h2>
        {lang === 'zh' ? '抢占AI先机' : lang === 'ja' ? 'AIの最前線をキャッチ' : 'Stay Ahead of the AI Curve'}
      </h2>
      <p class="sub">
        {lang === 'zh' ? '每日简报直达你的收件箱。没有垃圾邮件、没有废话 — 只有对你AI业务有价值的信号。' : lang === 'ja' ? 'デイリーブリーフを受信トレイに。スパムなし、無駄なし — あなたのAIビジネスに重要なシグナルだけ。' : 'Get the daily brief delivered to your inbox. No spam, no fluff — just signals that matter for your AI business.'}
      </p>
      <form class="newsletter-form" onsubmit="return false;">
        <input type="email" placeholder={lang === 'zh' ? '你的邮箱' : lang === 'ja' ? 'メールアドレス' : 'your@email.com'} />
        <button class="btn-primary" type="submit">
          {lang === 'zh' ? '订阅 →' : lang === 'ja' ? '登録 →' : 'Subscribe →'}
        </button>
      </form>
      <div class="newsletter-features">
        <div class="newsletter-feature">
          <span class="check">✓</span>
          {lang === 'zh' ? '每日AI信号' : lang === 'ja' ? '毎日のAIシグナル' : 'Daily AI signals'}
        </div>
        <div class="newsletter-feature">
          <span class="check">✓</span>
          {lang === 'zh' ? '工具深度评测' : lang === 'ja' ? 'ツール深掘り' : 'Tool deep-dives'}
        </div>
        <div class="newsletter-feature">
          <span class="check">✓</span>
          {lang === 'zh' ? '创业路径指南' : lang === 'ja' ? '起業プレイブック' : 'Solopreneur playbooks'}
        </div>
        <div class="newsletter-feature">
          <span class="check">✓</span>
          {lang === 'zh' ? '永久免费' : lang === 'ja' ? '永久無料' : 'Free forever'}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .newsletter {
    position: relative;
    border-radius: 16px;
    padding: 64px 48px;
    text-align: center;
    overflow: hidden;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
  }
  .newsletter::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(139,92,246,0.12) 0%, transparent 60%);
    pointer-events: none;
  }
  .newsletter h2 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    position: relative;
  }
  .newsletter .sub {
    color: var(--text-secondary);
    font-size: 16px;
    margin-bottom: 32px;
    position: relative;
  }
  .newsletter-form {
    display: flex;
    gap: 12px;
    max-width: 460px;
    margin: 0 auto 32px;
    position: relative;
  }
  .newsletter-form input {
    flex: 1;
    padding: 14px 20px;
    background: var(--bg-primary);
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    color: var(--text-primary);
    font-size: 14px;
    font-family: var(--font-sans);
    outline: none;
    transition: border-color 0.2s;
  }
  .newsletter-form input:focus { border-color: var(--accent-purple); }
  .newsletter-form input::placeholder { color: var(--text-muted); }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #8B5CF6, #3B82F6, #06B6D4);
    color: white;
    font-weight: 700;
    font-size: 15px;
    border-radius: 12px;
    text-decoration: none;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
    font-family: var(--font-sans);
    white-space: nowrap;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(139,92,246,0.3);
  }
  .newsletter-features {
    display: flex;
    justify-content: center;
    gap: 32px;
    position: relative;
  }
  .newsletter-feature {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-secondary);
  }
  .check {
    color: var(--accent-green);
    font-weight: 700;
  }
  @media (max-width: 768px) {
    .newsletter { padding: 40px 24px; }
    .newsletter-form { flex-direction: column; }
    .newsletter-features { flex-direction: column; align-items: center; gap: 12px; }
  }
</style>