---
interface PlaybookCard {
  slug: string;
  title: string;
  category?: string;
  snippet: string;
  outcome: string;
  bestFor: string;
  useWhen: string;
}

interface Props {
  lang: string;
  playbooks: PlaybookCard[];
}

const { lang, playbooks } = Astro.props;
const primary = playbooks[0];
const secondary = playbooks.slice(1);

const localizeCategory = (category?: string) => {
  if (!category) {
    return lang === 'zh' ? '实战手册' : lang === 'ja' ? 'プレイブック' : 'Playbook';
  }

  const labels: Record<string, { en: string; ja: string; zh: string }> = {
    Build: { en: 'Build', ja: '構築', zh: '搭建' },
    Media: { en: 'Media', ja: 'メディア', zh: '媒体' },
    Growth: { en: 'Growth', ja: '成長', zh: '增长' },
    Operations: { en: 'Operations', ja: '運営', zh: '运营' },
  };

  return labels[category]?.[lang as 'en' | 'ja' | 'zh'] ?? category;
};
---

<section class="section-block">
  <div class="container">
    <div class="playbooks-head">
      <div class="section-label">// PLAYBOOKS</div>
      <h2 class="section-title">
        {lang === 'zh'
          ? '按任务组织的 AI 实战手册'
          : lang === 'ja'
            ? 'AIで進めるためのタスク別ガイド'
            : 'Task-based guides for building with AI'}
      </h2>
      <p class="section-desc">
        {lang === 'zh'
          ? '把评测、案例和日常信号，重组为一套可以直接照着推进的做事顺序。'
          : lang === 'ja'
            ? 'レビュー、事例、日々のシグナルを、実際に辿れるひとつの進め方へ組み直します。'
            : 'This is where reviews, cases, and daily signals turn into one practical sequence you can actually follow.'}
      </p>
    </div>

    <div class="playbooks-grid">
      {primary && (
        <article class="playbook-primary">
          <div class="playbook-primary-copy">
            <p class="playbook-tag">{localizeCategory(primary.category)}</p>
            <h3><a href={`/${lang}/playbooks/${primary.slug}/`}>{primary.title}</a></h3>
            <p class="playbook-dek">{primary.snippet}</p>
            <div class="playbook-stat-list">
              <div>
                <span>{lang === 'zh' ? '能得到什么' : lang === 'ja' ? '得られる結果' : 'Outcome'}</span>
                <p>{primary.outcome}</p>
              </div>
              <div>
                <span>{lang === 'zh' ? '适合谁' : lang === 'ja' ? '向いている人' : 'Best for'}</span>
                <p>{primary.bestFor}</p>
              </div>
            </div>
          </div>
          <div class="playbook-primary-side">
            <p class="playbook-note-label">{lang === 'zh' ? '为什么现在读' : lang === 'ja' ? '今読む理由' : 'Why now'}</p>
            <p class="playbook-note">{primary.useWhen}</p>
            <a class="playbook-link" href={`/${lang}/playbooks/${primary.slug}/`}>
              {lang === 'zh' ? '打开这份 playbook →' : lang === 'ja' ? 'この playbook を読む →' : 'Open the playbook →'}
            </a>
          </div>
        </article>
      )}

      <div class="playbook-list">
        {secondary.map((playbook) => (
          <article class="playbook-row">
            <div class="playbook-row-top">
              <p class="playbook-tag">{localizeCategory(playbook.category)}</p>
              <a href={`/${lang}/playbooks/${playbook.slug}/`} class="playbook-row-link">
                {lang === 'zh' ? '查看' : lang === 'ja' ? '読む' : 'Read'}
              </a>
            </div>
            <h3><a href={`/${lang}/playbooks/${playbook.slug}/`}>{playbook.title}</a></h3>
            <p class="playbook-row-dek">{playbook.snippet}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .playbooks-head {
    margin-bottom: 40px;
    max-width: 760px;
  }
  .playbooks-head .section-desc {
    margin-bottom: 0;
  }
  .playbooks-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.9fr);
    gap: 18px;
  }
  .playbook-primary,
  .playbook-row {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    box-shadow: 0 16px 40px rgba(32, 27, 24, 0.04);
  }
  .playbook-primary {
    padding: 28px;
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) minmax(220px, 0.7fr);
    gap: 26px;
  }
  .playbook-primary-copy h3,
  .playbook-row h3 {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 0.98;
  }
  .playbook-primary-copy h3 {
    font-size: clamp(2.2rem, 4vw, 3.25rem);
    margin-bottom: 14px;
    max-width: 14ch;
  }
  .playbook-tag {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .playbook-dek,
  .playbook-row-dek,
  .playbook-note {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 0.98rem;
  }
  .playbook-stat-list {
    display: grid;
    gap: 14px;
    margin-top: 22px;
  }
  .playbook-stat-list div {
    padding-top: 14px;
    border-top: 1px solid var(--border-subtle);
  }
  .playbook-stat-list span,
  .playbook-note-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 8px;
  }
  .playbook-stat-list p {
    color: var(--text-primary);
    line-height: 1.7;
  }
  .playbook-primary-side {
    display: grid;
    align-content: space-between;
    gap: 18px;
    padding-left: 4px;
  }
  .playbook-link,
  .playbook-row-link {
    color: var(--accent);
    font-weight: 700;
    font-size: 0.88rem;
  }
  .playbook-list {
    display: grid;
    gap: 16px;
  }
  .playbook-row {
    padding: 22px 24px;
  }
  .playbook-row-top {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
    margin-bottom: 10px;
  }
  .playbook-row h3 {
    font-size: 2rem;
    margin-bottom: 10px;
  }
  @media (max-width: 980px) {
    .playbooks-grid,
    .playbook-primary {
      grid-template-columns: 1fr;
    }
    .playbook-primary-copy h3 {
      max-width: none;
    }
  }
  @media (max-width: 768px) {
    .playbook-primary,
    .playbook-row {
      border-radius: 20px;
      padding: 22px;
    }
    .playbook-row h3 {
      font-size: 1.75rem;
    }
  }
</style>
