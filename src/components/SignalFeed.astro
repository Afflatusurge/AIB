---
interface Brief {
  id: string;
  title: string;
  snippet: string;
  category: string;
  impact: string;
  date: string;
}

interface Props {
  lang: string;
  t: (key: string) => string;
  briefs: Brief[];
}

const { lang, t, briefs } = Astro.props;
const editorialTimeZone = 'America/Los_Angeles';
const editorialNow = new Date();

const categoryClass: Record<string, string> = {
  'LLM': 'llm',
  'Agent': 'agent',
  'Business': 'business',
  'Coding': 'coding',
  'Hardware': 'hardware',
  'Image': 'image',
  'Video': 'video',
};

const dateParts = new Intl.DateTimeFormat('en-US', {
  timeZone: editorialTimeZone,
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
}).formatToParts(editorialNow);
const year = dateParts.find((part) => part.type === 'year')?.value || '';
const month = dateParts.find((part) => part.type === 'month')?.value || '';
const day = dateParts.find((part) => part.type === 'day')?.value || '';
const today = `${year}-${month}-${day}`;
const dayOfWeek = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : lang === 'ja' ? 'ja-JP' : 'en-US', {
  timeZone: editorialTimeZone,
  weekday: 'long',
}).format(editorialNow);
---

<section class="section-block">
  <div class="container">
    <div class="section-label">{lang === 'zh' ? '// DAILY BRIEFING' : lang === 'ja' ? '// DAILY BRIEFING' : '// DAILY BRIEFING'}</div>
    <h2 class="section-title">
      {lang === 'zh' ? '把每天的重要变化整理成简报' : lang === 'ja' ? '毎日の変化を、読めるブリーフに整理する' : 'A daily brief, not a noisy feed'}
    </h2>
    <p class="section-desc">
      {lang === 'zh' ? '这里保留“快”和“新”，但读起来应该像编辑整理过的版面，而不是信息流。' : lang === 'ja' ? '速さと新しさは保ちつつ、読む体験は情報流ではなく編集済みの紙面に近づけます。' : 'Keep the speed of the news cycle, but present it with the hierarchy and calm of an editorial desk.'}
    </p>

    <div class="signal-feed animate-in">
      <div class="signal-summary">
        <p class="summary-kicker">{t('nav.daily')}</p>
        <h3>{lang === 'zh' ? '过去 24 小时，哪些 AI 动向值得独立创作者和小团队现在就关注？' : lang === 'ja' ? '過去24時間で、ひとり起業家が今すぐ見るべきAIの動きは何か。' : 'What mattered in AI over the last 24 hours for independent builders?'}</h3>
        <p class="summary-copy">
          {lang === 'zh' ? '按影响力和可执行性排序，而不是按热度堆砌。' : lang === 'ja' ? '話題性ではなく、影響と実行可能性で優先順位をつけます。' : 'Ranked by business impact and immediate usefulness, not by hype alone.'}
        </p>
        <div class="summary-date">{today} · {dayOfWeek}</div>
      </div>
      <div class="signal-items">
        {briefs.length > 0 ? briefs.slice(0, 6).map((brief, i) => (
          <a href={`/${lang}/daily/${brief.slug || brief.id}/`} class="signal-item">
            <div class="signal-index">{String(i + 1).padStart(2, '0')}</div>
            <div class="signal-main">
              <div class="signal-row">
                <span class={`signal-category ${categoryClass[brief.category] || 'llm'}`}>{brief.category || 'AI'}</span>
                <span class={`signal-impact ${brief.impact.toLowerCase()}`}>{brief.impact || 'Notable'}</span>
              </div>
              <h4>{brief.title}</h4>
              <p>{brief.snippet}</p>
            </div>
          </a>
        )) : (
          <div class="signal-empty">
            <p>{lang === 'zh' ? '暂无信号数据。连接 Notion 后将显示实时内容。' : lang === 'ja' ? 'シグナルデータがありません。Notion接続後にライブコンテンツが表示されます。' : 'No signal data yet. Live content will appear once Notion is connected.'}</p>
          </div>
        )}
      </div>
      <div class="signal-footer">
        <a href={`/${lang}/daily/`}>
          {lang === 'zh' ? '查看完整简报 →' : lang === 'ja' ? 'フルブリーフを見る →' : 'View Full Brief →'}
          {briefs.length > 6 && ` ${briefs.length - 6} more signals`}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .section-block { padding: 80px 0; }
  .section-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
  }
  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2.1rem, 4vw, 3.8rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
    line-height: 1;
    white-space: nowrap;
  }
  .section-desc {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 40px;
    max-width: 720px;
    line-height: 1.75;
  }
  .signal-feed {
    background: linear-gradient(180deg, rgba(239, 229, 214, 0.48), rgba(251, 248, 241, 0.92));
    border: 1px solid var(--border-subtle);
    border-radius: 28px;
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(280px, 0.42fr) minmax(0, 1fr);
  }
  .signal-summary {
    padding: 28px 24px;
    border-right: 1px solid var(--border-subtle);
    display: flex;
    flex-direction: column;
  }
  .summary-kicker {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .signal-summary h3 {
    font-family: var(--font-display);
    font-size: 2.2rem;
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 14px;
  }
  .summary-copy {
    color: var(--text-secondary);
    font-size: 0.96rem;
    line-height: 1.75;
    margin-bottom: auto;
  }
  .summary-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .signal-items {
    padding: 12px;
  }
  .signal-item {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr);
    gap: 16px;
    padding: 18px 16px;
    border-radius: 18px;
    transition: background 0.2s, transform 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .signal-item:hover {
    background: rgba(255, 255, 255, 0.36);
    transform: translateX(2px);
  }
  .signal-index {
    font-family: var(--font-mono);
    font-size: 0.86rem;
    color: var(--text-muted);
    padding-top: 4px;
  }
  .signal-main {
    min-width: 0;
  }
  .signal-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
    flex-wrap: wrap;
  }
  .signal-category {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    padding: 4px 8px;
    border-radius: 999px;
    text-align: center;
    white-space: nowrap;
  }
  .signal-category.llm { background: rgba(177, 90, 53, 0.12); color: var(--accent); }
  .signal-category.agent { background: rgba(61, 100, 120, 0.12); color: var(--accent-cyan); }
  .signal-category.business { background: rgba(79, 122, 90, 0.12); color: var(--accent-green); }
  .signal-category.coding { background: rgba(61, 100, 120, 0.12); color: var(--accent-blue); }
  .signal-category.hardware { background: rgba(159, 107, 47, 0.12); color: var(--accent-amber); }
  .signal-category.image { background: rgba(154, 87, 111, 0.12); color: var(--accent-pink); }
  .signal-category.video { background: rgba(154, 87, 111, 0.12); color: var(--accent-pink); }
  .signal-text h4 {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 2px;
    line-height: 1.4;
  }
  .signal-main h4 {
    font-family: var(--font-display);
    font-size: 1.7rem;
    line-height: 1;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
  }
  .signal-main p {
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }
  .signal-impact {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    padding: 4px 9px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .signal-impact.major { background: rgba(154, 87, 111, 0.12); color: var(--accent-pink); }
  .signal-impact.notable { background: rgba(159, 107, 47, 0.12); color: var(--accent-amber); }
  .signal-impact.routine { background: rgba(82, 72, 63, 0.08); color: var(--text-muted); }
  .signal-empty {
    padding: 48px 24px;
    text-align: center;
    color: var(--text-muted);
    font-size: 14px;
  }
  .signal-footer {
    padding: 20px 24px;
    border-top: 1px solid var(--border-subtle);
    text-align: center;
    grid-column: 1 / -1;
  }
  .signal-footer a {
    font-size: 13px;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    transition: color 0.2s;
  }
  .signal-footer a:hover { color: var(--text-primary); }
  @media (max-width: 768px) {
    .section-title {
      white-space: normal;
    }
    .signal-feed {
      grid-template-columns: 1fr;
      border-radius: 22px;
    }
    .signal-summary {
      border-right: 0;
      border-bottom: 1px solid var(--border-subtle);
    }
    .signal-item {
      grid-template-columns: 40px minmax(0, 1fr);
      gap: 10px;
      padding: 14px 12px;
    }
    .signal-main h4 {
      font-size: 1.35rem;
    }
  }
</style>
