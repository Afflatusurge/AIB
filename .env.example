# ─────────────────────────────────────────────────────────────
# Notion API  (editorial content: tool reviews, cases, playbooks,
# and the manually curated lead brief shown in Hero / Bento /
# FeaturedCards on the homepage)
# ─────────────────────────────────────────────────────────────
NOTION_API_KEY=your_notion_integration_token

# Notion Database IDs (EN)
NOTION_DB_DAILY_EN=
NOTION_DB_TOOLS_EN=
NOTION_DB_CASES_EN=

# Notion Database IDs (JA)
NOTION_DB_DAILY_JA=
NOTION_DB_TOOLS_JA=
NOTION_DB_CASES_JA=

# Notion Database IDs (ZH)
NOTION_DB_DAILY_ZH=
NOTION_DB_TOOLS_ZH=
NOTION_DB_CASES_ZH=

# ─────────────────────────────────────────────────────────────
# Supabase (runtime store for the live Daily Brief)
# ─────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
# Publishable/anon key — safe for SSR and browser; powers read-only
# access governed by RLS (`status = 'published'`).
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Service role key — server-only. Used by the cron ingest and the
# one-shot Notion→Supabase migration script.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─────────────────────────────────────────────────────────────
# OpenAI
# /api/cron/ingest makes ONE Responses API call per run. The model
# uses the built-in web_search_preview tool to discover today's AI
# news, then returns structured en/zh/ja briefs in a single shot.
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional. Must be a model that supports the Responses API
# web_search_preview tool. Default: gpt-4o.
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# Cron protection — any random string. Vercel Cron sends it as
# Authorization: Bearer <CRON_SECRET> automatically.
# ─────────────────────────────────────────────────────────────
CRON_SECRET=

# ─────────────────────────────────────────────────────────────
# Site URL (for sitemap and RSS)
# ─────────────────────────────────────────────────────────────
SITE_URL=https://aiandbusiness.com
